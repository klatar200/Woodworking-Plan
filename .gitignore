# Dependencies
node_modules/
venv/
.venv/
__pycache__/
*.pyc

# Environment / secrets
.env
.env.*
!.env.example

# Build output. Anchored to the repo root: an unanchored `build/`/`dist/`/`out/`
# matches a directory of that name at ANY depth — which silently swallowed the
# App Router route segment `src/app/plans/[slug]/build/`, so its page.tsx could
# never be committed (the P0-1 "Start building" 404). Keep these root-only.
/dist/
/build/
/out/
.next/
.nuxt/

# Next.js / Vercel
next-env.d.ts
.vercel/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp

# Test/coverage
coverage/
.nyc_output/

# Agent tooling (local session state, not project source)
.agents/
skills-lock.json
# Skills are cloned in as their OWN git repos. Committing one stores a gitlink
# (mode 160000) — a pointer with no contents — so every fresh clone and CI run
# gets an empty directory it cannot populate. Not project source; keep it out.
.claude/skills/

# Misc
*.tmp
.cache/

# clerk configuration (can include secrets)
/.clerk/

# design-sync (claude.ai/design system sync). Staged converter scripts, build
# output, and machine state are regenerated per run. The durable inputs stay
# committed: .design-sync/config.json, NOTES.md, conventions.md, previews/,
# overrides/, and the ds-source package's src (but not its build output/deps).
.ds-sync/
/ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
.design-sync/ds-source/node_modules/
.design-sync/ds-source/dist/

# Scratch / audit artifacts
plans.json
eslint-errors*.txt
_to_delete/
run1-*-report.json

# Run 1 ledger is committed per batch (it IS the resume point)
!run1-ledger.json
