# Normalize line endings.
#
# Without this, a Windows checkout rewrites every file to CRLF and git reports
# every tracked file as fully modified, which buries real diffs in noise.
# Text files are stored LF in the repo and checked out natively.
* text=auto eol=lf

# Windows-native scripts must keep CRLF to run correctly.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary — never touch these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
