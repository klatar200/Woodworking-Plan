  "steps": [
    {
      "title": "Watch the Build Video",
      "body": "See this project come together in this video:"
    },
    {
      "title": "Lay out supports",
      "body": "Layout the 4x4s as shown. Locate center of each 4x4 joint and use a 1-1/8\" forstener bit to counterbore a 1/2\" deep hole. Then, drill a 1/4\" pilot hole through the center (as shown). You'll repeat this step three times for each support.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6fa80a00bdc05b1a.webp"
    },
    {
      "title": "Assemble legs",
      "body": "Assemble each leg assembly with four 3/8\" x 5-1/2\" lag screws and washers using an impact wrench.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6d7d844033150a0b.webp"
    },
    {
      "title": "Attach leg assemblies",
      "body": "Attach the leg assemblies together with two 2x8s using 3\" timber or deck screws. Make sure middle leg assembly is centered.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d5fbc1d73fa4c5c7.webp"
    },
    {
      "title": "Install table top boards",
      "body": "Finish table assembly by installing remaining 2x8s using 3\" timber or deck screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/595ea90fcdebddaa.webp"
    }
  ],
