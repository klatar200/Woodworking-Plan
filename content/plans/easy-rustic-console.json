  "steps": [
    {
      "title": "Taper the table legs (optional)",
      "body": "If you would like to add a little flair to your console, taper the ends of each table leg (board D) with a jigsaw.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/99f747878e3fe32e.webp"
    },
    {
      "title": "Create pocket holes",
      "body": "If you use pocket hole joints, use a Kreg Jig to drill the pocket holes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/50972a790647153d.webp"
    },
    {
      "title": "Assemble the console legs",
      "body": "To form a pair of table legs, sandwich board E between boards D. Offset board E 1″ from the edge of board D. Repeat.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9d0aad6b05150364.webp"
    },
    {
      "title": "Connect the pair of legs",
      "body": "Connect the pair of legs together with boards C. This will form the frame of the console.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2646e6f3c9c357cc.webp"
    },
    {
      "title": "Attach the shelf supports",
      "body": "Attach the shelf supports (boards A) to each pair of legs. Attach the shelf supports adjacent to the inside edge of the table leg pairs. The first set of shelf supports are placed 13 3/4″ from the top of the leg. The second set of shelf supports are placed 25 1/2″ from the top of the leg.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ec84b766fae94905.webp"
    },
    {
      "title": "Edge join the console shelves",
      "body": "Create the top shelf by edge joining boards F and H together. Board H should be in the middle.\nCreate the two lower shelves by joining boards G and B together. Board B should be in the middle.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/71d3c346363a6abf.webp"
    },
    {
      "title": "Attach the top shelf",
      "body": "Attach the top shelf to the console frame.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ff3f5bd1c243436f.webp"
    },
    {
      "title": "Attach the bottom shelves",
      "body": "Attach the lower shelves to the console shelf supports",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/588385a8a357d42a.webp"
    },
    {
      "title": "Apply the finish",
      "body": "Thoroughly sand the console. Use your favorite stain and sealer to finish the console.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/995f33063d703d1d.webp"
    }
  ],
