    },
    {
      "title": "Rear panel",
      "body": "Cut and assemble the rear panels utilizing 1 1/4\" pocket hole screws",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4d9ef5d824bbbdc7.webp"
    },
    {
      "title": "Front panel",
      "body": "Cut and assemble the front panel utilizing 1 1/4\" pocket hole screws",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/135571c26090130f.webp"
    },
    {
      "title": "Left side panel",
      "body": "Assemble the left side panel utilizing 1 1/4\" pocket hole screws If you do not need the opening for cat access, eliminate the middle cross piece.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/34f9386f9cbe2ad1.webp"
    },
    {
      "title": "Assemble all componets",
      "body": "Assemble all panels utilizing 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fd3e23cba9dcb4ad.webp"
    },
    {
      "title": "Install the bottom plywood",
      "body": "Cut the bottom plywood and install with 1 1/4\" pocket hole screws. Locate the panel 2\" up from the bottom.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/620d58d23ce771c3.webp"
    },
    {
      "title": "Install plywood",
      "body": "Cut and install side and rear plywood/beadboard panels utilizing your nail gun. Install the interior divider panel in a location that works for you with 1 1/4\" pocket hole screws. If you do not need the cat access, the left plywood/beadboard panel size will be the same size as the right panel. You can also eliminate the interior divider panel.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ec1dfec5ab5c8d3c.webp"
    },
    {
      "title": "Construct the doors",
      "body": "Cut the door parts and assemble with 1 1/4\" pocket hole screws. Route a 1/4\" recess in the back of the door panels to accept the plywood/beadboard infill.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8cf1e3ce7a660c7a.webp"
    },
    {
      "title": "Install doors",
      "body": "Install the doors as shown utilizing your choice of hardware",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f5ec6ad6c41a9d2a.webp"
    },
    {
      "title": "Install the base trim.",
      "body": "Utilize your nail gun to install the base trim.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6e13db385681221c.webp"
    },
    {
      "title": "Construct the top",
      "body": "Choose the type of wood you would like to utilize and cut to size to allow a 1 1/2\" overhang on the sides and front. I utilized poplar boards that I joined, cut to width, sanded and routed a decorative edge on the sides and front.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/63656ebb0a07cdf2.webp"
    },
    {
      "title": "Install the top",
      "body": "Choose the type of wood you would like to utilize and cut to size to allow a 1 1/2\" overhang on the sides and front. I utilized poplar boards that I joined, cut to width, sanded and routed a decorative edge on the sides and front.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b2c8ed5c38d7a392.webp"
    },
    {
      "title": "Finish the cabinet",
      "body": "Finish the cabinet by painting or staining per your preference"
    }
