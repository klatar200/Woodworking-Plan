  "cutList": [],
  "steps": [
    {
      "title": "Step one",
      "body": "Cut the plywood to size. Set your pocket hole jig and stop collar to 3/4”. Pocket hole the top and bottom of the jewelry box. Attach to the sides with 1 1/4” pocket hole screws and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/829b3269553b41d8.webp"
    },
    {
      "title": "Step two",
      "body": "Pocket hole and glue the doors together.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/aab147f45db874ef.webp"
    },
    {
      "title": "Step three",
      "body": "Spackle the pocket holes and plywood edges. Optional: edge banding the plywood edges.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0f56c0d8e9fb6d5d.webp"
    },
    {
      "title": "Step four",
      "body": "Rabbet the back side of the box and attach back with nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5201d5d9f9f80d96.webp"
    },
    {
      "title": "Step five",
      "body": "Glue and nail the drawer box together.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a6d7f6a61d89cb51.webp"
    },
    {
      "title": "Step six",
      "body": "Attach drawer slides to jewelry box.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/85355191a4da11cd.webp"
    },
    {
      "title": "Step seven",
      "body": "Cut drawer front and attach with brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d2c27d96cf814008.webp"
    },
    {
      "title": "Step eight",
      "body": "Pocket hole the divider and attach just above the drawers with screws and glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4fc00853cad06954.webp"
    },
    {
      "title": "Step nine",
      "body": "Find the center of the drawer and cut the handle to the shape and size you want."
    },
    {
      "title": "Step ten",
      "body": "Pocket hole the legs and glue to the underside of the main box. Make sure the pocket holes face down so they aren’t visible.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b2e73b81fc0deb9e.webp"
    },
    {
      "title": "Step eleven",
      "body": "Paint the main box, insides, legs and door with the color of your choice.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/59b21e5f5b2d2aa8.webp"
    },
    {
      "title": "Step twelve",
      "body": "Attach the doors using the small hinges.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e04912324032e77b.webp"
    },
    {
      "title": "Step thirteen",
      "body": "Attach the knobs by finding the center of your door, drill and screw in.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/94e94ddc5c1f6a1b.webp"
    },
    {
      "title": "Step fourteen",
      "body": "Predrill for the hooks in the necklace holder and screw them in. Attach to the inside top of the jewelry box with pocket holes and glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/89f0d3a0916faa56.webp"
    },
    {
      "title": "Step fifteen",
      "body": "Using your router and a rabbeting bit, rabbet the inside back of the doors."
    },
    {
      "title": "Step sixteen",
      "body": "Cut the acrylic or glass to size and fit into the rabbet of the doors. Use glazing points to keep them in place.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/33757e4dbfd16dc2.webp"
    },
    {
      "title": "Step seventeen",
      "body": "Enjoy your new jewelry box!"
    }
  ],
