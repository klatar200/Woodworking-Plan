  "steps": [
    {
      "title": "Cut Your Wood",
      "body": "Cut your wood to specified dimensions. (Can be modified to your preferences depending on how large you want your tray to be.)",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/00f2cc3430f5ce13.webp"
    },
    {
      "title": "Drill Pocket Holes",
      "body": "Drill 3 pocket holes along each side of your project panel. I used the Kreg Jig 520PRO for this.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2b4fa6354fb4de3d.webp"
    },
    {
      "title": "Sand",
      "body": "Sand edges smooth."
    },
    {
      "title": "Attach Your Wood",
      "body": "Using 1 1/4\" pocket hole screws, attach your tray sides to the project panel, ensuring that your pocket hole screws will end up on the bottom of the tray.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9a73549ebd57ad52.webp"
    },
    {
      "title": "Drill Holes for Handles",
      "body": "Measure your handles to see how far apart the holes need to be. I recommend using a piece of painter's tape as a template and marking where the holes should go, then placing that on the sides of the tray and drilling through it.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fcfb4ea1a3a1b3db.webp"
    },
    {
      "title": "Paint or Stain",
      "body": "Paint or stain your tray according to your preference. I used a special walnut stain for this one."
    },
    {
      "title": "Add Handles",
      "body": "Add your handles, and enjoy!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f387e70255de148f.webp"
    }
  ],
