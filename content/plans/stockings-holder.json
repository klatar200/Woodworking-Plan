  "steps": [
    {
      "title": "Make All Cuts",
      "body": "Make all the cuts according to the cut list.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/38246fd598b616ce.webp"
    },
    {
      "title": "Add Pocket Holes to Mantel Base",
      "body": "Add two pocket holes on the Mantel Base in three locations: 20\" (center of board) and 8\" in from either side.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2012d68b7c226541.webp"
    },
    {
      "title": "Add Pocket Holes to Hook Piece 2",
      "body": "Add a single pocket hole going in both directions of Hook Piece 2.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/56503765a35fb7ad.webp"
    },
    {
      "title": "Build Hooks",
      "body": "Build the three hooks. Use the two pocket holes to attach Hook Piece 2 to the base of Hook Piece 1 and Hook Piece 3.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/54465d18245f09ae.webp"
    },
    {
      "title": "Attach Hooks",
      "body": "Attach the hooks to the outside of the Mantel Base where you drilled the pocket holes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ea598bf3046626fa.webp"
    },
    {
      "title": "Router the Edge",
      "body": "Use a palm router around the edge of the Mantel Base, going over the top of the hooks. This will help make it look like one piece of wood.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/06ce61530434b100.webp"
    },
    {
      "title": "Stain the Wood",
      "body": "Choose a nice wood stain to match your decor.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/79dc1646a7b4d2d0.webp"
    },
    {
      "title": "Hang Your Stockings",
      "body": "Santa is coming! Hang your stockings on this beautiful stockings holder and make sure to put out a plate of cookies and a cup of milk!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7b59d35cd4df2afb.webp"
    },
    {
      "title": "Visit www.CharlestonCrafted.com",
      "body": "Check out www.CharlestonCrafted.com for more great holiday projects like these!"
    }
  ],
