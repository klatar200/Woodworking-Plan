  "cutList": [],
  "steps": [
    {
      "title": "Cut and Attach One Side",
      "body": "Cut two 1x6s as shown, clamp the two boards together and use a 3/4\" spade or forstner drill bit to drill the hole for the dowel. Then attach one 1x4 side to one 1x6 end with 1-1/4\" brad nails and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b649933e4396de8d.webp"
    },
    {
      "title": "Attach Other Side",
      "body": "Attach the other side to one 1x6 end with 1-1/4\" brad nails and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/14447737a1056449.webp"
    },
    {
      "title": "Insert Dowel",
      "body": "Squeeze some wood glue in the dowel hole and insert the 3/4\" dowel, using a mallet to hammer it into place.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9bb7f258e7e40d07.webp"
    },
    {
      "title": "Attach Other End",
      "body": "Squeeze some wood glue into the dowel hole and use a mallet to hammer the dowel into place. Then use 1-1/4\" brad nails and wood glue to attach the other 1x6 end.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f0ce6a21982a470e.webp"
    },
    {
      "title": "Attach Bottom",
      "body": "Attach the 1/4\" plywood bottom with 3/4\" staples or brad nails and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3ba84cc6614371fe.webp"
    },
    {
