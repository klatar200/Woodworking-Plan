  "steps": [
    {
      "title": "Cut Wood",
      "body": "Cut boards for back and top of purse rack to listed dimensions (or modify if you want it to be longer).",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5a250cc19b2b317f.webp"
    },
    {
      "title": "Drill Pocket Holes",
      "body": "Drill 3 pocket holes along one side of your 1x3 board.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5a207b3140d53abe.webp"
    },
    {
      "title": "Sand",
      "body": "Sand everything smooth."
    },
    {
      "title": "Attach Top and Side",
      "body": "Attach your 1x3 board to your 1x6 board using 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/909c2dcf2ce729f4.webp"
    },
    {
      "title": "Drill Holes for Hooks",
      "body": "Measure, mark, and drill holes for your purse hooks. I found it helpful to use a speed square to make sure my holes would be straight and level.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ee71dd401abb3ddb.webp"
    },
    {
      "title": "Stain",
      "body": "Stain or paint your purse rack. I used an Early American color stain.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d86b62fb9cb8b0cc.webp"
    },
    {
      "title": "Attach Hooks",
      "body": "Attach hooks. I used the screws that came with the hooks I ordered, and ended up having to use a Dremel to trim the backs since they were too long, so I recomend purchasing shorter screws separately.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7ea75f10c3200b36.webp"
    },
    {
      "title": "Hang",
      "body": "Use picture hanging hardware to attach your rack to the wall.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/aec678cd742f5d82.webp"
    }
  ],
