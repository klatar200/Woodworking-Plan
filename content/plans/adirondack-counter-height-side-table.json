  "steps": [
    {
      "title": "Dimensions",
      "body": "22\"diameter top x 36\"h",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a9b67180471791ed.webp"
    },
    {
      "title": "Step 1",
      "body": "STEP 1: Attach short side aprons to legs using wood glue and 1 ¼” pocket hole screws. Keep apron inset 3/8”. Make 2 sets.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/afdaa697dfe52b41.webp"
    },
    {
      "title": "Step 2",
      "body": "STEP 2: Attach long side aprons to short side panels at legs using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d2c3c679babf8262.webp"
    },
    {
      "title": "Step 3",
      "body": "STEP 3: Attach table top pieces to aprons using wood glue and 1 ¼” pocket hole screws. Keep 1/8” spacing between boards. Use a jig saw to trim boards to 22” diameter circle.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a7afa6f98c4b8b41.webp"
    },
    {
      "title": "Step 4",
      "body": "STEP 4: Attach bottom shelf slats to aprons using wood glue and 1 ¼” finish nails. Notch out corners using jigsaw to fit around legs.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0de8193081ae1428.webp"
    }
  ],
