  "steps": [
    {
      "title": "Cut pieces",
      "body": "Cut top, bottom, and side pieces to length (if needed)\nMiter corners at 45 degrees for top, bottom, and side pieces",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e7d2a8cf1f8ea752.webp"
    },
    {
      "title": "Groove",
      "body": "Using a table saw, make a 5/16” groove cut in the center of all pieces (using 1/4” thick mirror)",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f721d90b7fb27f75.webp"
    },
    {
      "title": "Drill pocket holes",
      "body": "We used the pocket-hole jig 720PRO",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9f1f488979b73c10.webp"
    },
    {
      "title": "Assemble Bottom and Side Pieces",
      "body": "Using two 1 1/4” pocket hole screws on each corner\nOptional to add One 2 1/2” pocket-hole screw at the top and bottom of each corner for additional stability",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/460284a35c44a95f.webp"
    },
    {
      "title": "Slide Mirror",
      "body": "Slide mirror into groove",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/57b1c7a96a0278d6.webp"
    },
    {
      "title": "Assemble top piece",
      "body": "Using two 1 1/4” pocket hole screws on each corner"
    },
    {
      "title": "Optional",
      "body": "Add One 2 1/2” pocket-hole screw at the top and bottom of each corner for additional stability",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/92077d109d5d8705.webp"
    },
    {
      "title": "Install D-Ring Hangers",
      "body": "Use two hangers equally spaced from edge of mirror on the back of the top piece",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/82c800107e2c6af5.webp"
    }
