  "steps": [
    {
      "title": "Cut boards and drill holes needed",
      "body": "Cut all boards according to the cut list. Drill holes with a 3/8\" spade bit in the (12) 19\" boards and the (9) 25\" boards. The picture shows the location of the holes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/77011c130439fc50.webp"
    },
    {
      "title": "Drill pocket holes",
      "body": "Drill pocket holes in the 25” boards. They should be 6” from the edge of each side.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5edafc1153e9891c.webp"
    },
    {
      "title": "Sand or Paint Boards",
      "body": "Completely sand your boards and paint or stain. This is very difficult to do once the table is assembled."
    },
    {
      "title": "Assemble Shelves",
      "body": "Place two of the 18” 1x2 boards across eight of your 48” 1x3 boards and screw in with 1 ¼” wood screws. Repeat until you have three shelf units. 1x2 boards should be placed 6” from each edge.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ca7b0c9fbeb45159.webp"
    },
    {
      "title": "Assemble Legs of Table",
      "body": "Place 3 – 1x3 @ 25” between 3- 1x3 @ 19”. Secure with a bolt, washer, and hex nut. The holes drilled with the spade bit will be the placement of the boards. Tighten the nuts to ensure the stability of the table. Make three of these.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0c5e22f66d152076.webp"
    },
    {
      "title": "Install Shelf Units to Legs",
      "body": "Attach the shelf units you assembled in step 4 to the leg supports with pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/70510543a80907e6.webp"
    }
  ],
