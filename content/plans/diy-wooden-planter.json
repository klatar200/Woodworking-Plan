  "steps": [
    {
      "title": "Cut Your Wood",
      "body": "Cut your wood to the specified dimensions.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2aa3720dd53e56d9.webp"
    },
    {
      "title": "Drill Pocket Holes",
      "body": "Drill 3 pocket holes along 2 parallel sides of each 1x12x12 boards, and 1 pocket hole at each end of the 1x2 pieces.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5984e1a369b7ca2a.webp"
    },
    {
      "title": "Sand",
      "body": "Use a sanding block to sand edges smooth."
    },
    {
      "title": "Attach Legs to Front and Back",
      "body": "Using 1 1/4\" pocket hole screws, attach 2 legs to one of the 1x12x12 pieces. Repeat. These will be the front and back of the planter.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6d1c4ce88da99a81.webp"
    },
    {
      "title": "Attach Sides",
      "body": "Attach remaining 1x12x12 pieces (the sides) to the front and back you assembled in the previous step.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e953ea1b9afb910c.webp"
    },
    {
      "title": "Add Bottom Slats",
      "body": "Use 1 1/4\" pocket hole screws to attach bottom slats (1x2 pieces). You can use a scrap piece of wood as a spacer or just eyeball it and try to space them as evenly as possible. It will not be visible so doesn't have to be perfect.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9b7dc2eb3dc6c310.webp"
    },
    {
      "title": "Paint or Stain",
      "body": "Finish your planter with any paint or stain of your choice.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4badefd66cf1c265.webp"
    }
  ],
