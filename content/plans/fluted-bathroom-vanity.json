  "steps": [
    {
      "title": "1",
      "body": "Cut and attach the side panels together using wood glue and 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7f7c4b9ca0d984d2.webp"
    },
    {
      "title": "2",
      "body": "Cut the panel to size using a table saw, track saw or circular saw."
    },
    {
      "title": "3",
      "body": "Attach the bottom panel of the cabinet to the sides of the cabinet using wood glue and 1 1/4\" pocket hole screws. Make sure the bottom of the cabinet is 3.5\" inches off the floor."
    },
    {
      "title": "4",
      "body": "Cut the face frame to size and attach together using 1 1/4\" pocket hole screws and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/de9e160ee4b4d205.webp"
    },
    {
      "title": "5",
      "body": "Nail the face frame onto the cabinet box using 1 1/2\" brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/06671d9601f90edb.webp"
    },
    {
      "title": "6",
      "body": "After routing the fluted trim and cutting it to size, use CA glue and glue the trim onto the backboard.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/acdf0a9885da3f49.webp"
    },
    {
      "title": "7",
      "body": "Cut the doors to size and using the Kreg Hinge Jig drill the cup holes for the hinges.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/76b05afe2e6636de.webp"
    },
    {
      "title": "8",
      "body": "Add trim to the door fronts, using CA Glue. (optional)",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4ebc882f18202e43.webp"
    },
    {
      "title": "9",
      "body": "Attach the doors to the cabinet. Make sure to have an even reveal on all sides."
    },
    {
      "title": "10",
      "body": "Use a roundover bit to route the trim for underneath the countertop. Cut to size and attach with CA glue. (optional)"
    },
    {
      "title": "11",
      "body": "Sand and stain the color of your choice!"
    }
  ],
