  "steps": [
    {
      "title": "Sawhorses",
      "body": "Build or purchase two, 24\" tall, wood sawhorses. Make sure the top plate runs horizontally.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0f303cfdb6c23de5.webp"
    },
    {
      "title": "Drill Holes in Top Plate",
      "body": "Drill two, 1-1/8\" holes through the top plate of the sawhorse, centered between the legs and 3-3/8\" from either end.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/573394620f62b46b.webp"
    },
    {
      "title": "Tray Base Plate",
      "body": "Cut a 28-1/2\" long tray base board from a 2 x 4.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/bbd7f062c9f86437.webp"
    },
    {
      "title": "Base Sides",
      "body": "Attach 1 x 3 side boards to both long sides of tray bottom. Pre-drill through sides and into base. Secure in place using wood glue and 2\" screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5aa5c44f47cbeaa3.webp"
    },
    {
      "title": "Base Ends",
      "body": "Attach 1 x 3 x 5\" end boards to the short sides of the tray assembly. Secure in place using glue and 2\" screws driven through pre-drilled holes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fab09018a588ba93.webp"
    },
    {
      "title": "Pipe Flanges",
      "body": "Attach 3/4\" pipe flanges to the underside of the tray. Center flanges between the sides and space approximately 26-1/2\" center-to-center. Secure in place using 1-1/4\" screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/953b740c9db7f3ab.webp"
    },
    {
      "title": "Add Pipes",
      "body": "Screw 3/4\" x 18\" pipes into the floor flanges on the underside of the tray.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/106bd49ffb88bb86.webp"
    },
    {
      "title": "Insert Tray",
      "body": "Place the sliding ends of the pipe clamps over the holes drilled in the sawhorse top plate, levers facing inward. Slide ends of pipes through the openings in the clamps through the top of the sawhorse.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7e11e03751294768.webp"
    },
    {
      "title": "Pipe Caps",
      "body": "Screw on 3/4\" pipe caps to the bottom ends of the 18\" pipes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d24d88b1ba9b10bd.webp"
    },
    {
      "title": "Place Unistrut",
      "body": "Place 24\" steel Unistrut on top of the pipe clamp tabs, making sure the ends engage both clamps and allow the pipes to slide.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/22f4d4d1e7c08c2b.webp"
    },
    {
      "title": "Rope Holes",
      "body": "Mark locations of holes in Unistrut onto the top of sawhorse. Drill 5/16\" holes through the top, spaced closely to the edges.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f3772137f0d63f65.webp"
    },
    {
      "title": "Add Rope",
      "body": "Loop a length of nylon rope through underside of sawhorse top plate and through two, widespread openings in the Unistrut. Adjust the length of the loop to be comfortable to pull down with your foot. Tuck the ends of rope back through adjacent holes and tie them into a knot. Seal the ends of rope and hide knot under the Unistrut.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/009b5386a43a6115.webp"
    },
    {
      "title": "Add Sacrificial Board",
      "body": "Lower 2 x 4 x 28-1/2\" sacrificial board or attachment top into the tray.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3c7b727147900713.webp"
    },
    {
      "title": "Optional: Outfeed Roller",
      "body": "Create a 3-1/2\" x 28-1/2\" hardwood and PVC roller.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/53ac724b370bd806.webp"
    },
    {
      "title": "Roller",
      "body": "Using a dense hardwood dowel, like oak will allow the PVC to roll easily and won't wear out quickly.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/caeabc358875958b.webp"
    },
    {
      "title": "Optional: Pointed Dowels",
      "body": "Build a 3-1/2\" x 28-1/2\" insert with 1/4\" pointed, sharpened dowels, glued into a base board. The pointed dowels work well to support a freshly painted surface.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5baeb3b1ecd2727f.webp"
    },
    {
      "title": "Optional: Ball Bearing Casters",
      "body": "Build a 3-1/2\" x 28-1/2\" insert and attach inset ball bearing casters. Ball bearing casters spin in all directions and are good to moving large or heavy materials.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0fe6607bfee2d6e7.webp"
    },
    {
      "title": "Get More Ideas",
      "body": "Check out the Pneumatic Addict channel on YouTube and visit PneumaticAddict.com for more free project plans and DIY ideas.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c2624f838f23dbb2.webp"
    }
  ],
