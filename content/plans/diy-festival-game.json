  "steps": [
    {
      "title": "Attach the side frame",
      "body": "Attach the side frames to the plywood base with wood glue and 1 1/4\" Brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e0a068dfae7a8628.webp"
    },
    {
      "title": "Attach the puck goal",
      "body": "Attach the puck goal 4\" from the edge of the plywood base with wood glue and 1 1/4\" Brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e50801dc2e445065.webp"
    },
    {
      "title": "Attach the back frame",
      "body": "Attach the back frame to the plywood base and frame sides with wood glue and 1 1/4\" Brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4405d8f985bb4c95.webp"
    },
    {
      "title": "Prep the surface for painting",
      "body": "Sand all the boards and the surface of the plywood. Take your time and cycle through 80, 100, 150, 220 grits of sand paper. (Avoid using some of the lower grits of sandpaper on the plywood. For the plywood, start with 150 grit.)"
    },
    {
      "title": "Paint and Seal",
      "body": "Paint the boards to your heart’s content and seal the surface with your favorite top coat. Check out the link in the \"Extras\" tab for more photos and happy building!",
