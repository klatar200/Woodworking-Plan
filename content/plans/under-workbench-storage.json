  "steps": [
    {
      "title": "Watch Video",
      "body": "Check out the video first, and as you build. It'll help with a few instructions!"
    },
    {
      "title": "Cut Parts",
      "body": "Cut down plywood parts according to the cutlist provided above",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d36672d8e551445d.webp"
    },
    {
      "title": "Drill Pocket Holes",
      "body": "Grab all of your 3/4\" thick plywood brace pieces to construct the case and drill pocket holes into them",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4325ce21ae8bc0bb.webp"
    },
    {
      "title": "Construct Case",
      "body": "Using 1 1/4 pocket hole screws, assemble the case together",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0ca1ebf6a9e3480a.webp"
    },
    {
      "title": "Cut Drawer Dados",
      "body": "In all of the 1/2\" thick plywood drawer pieces, (excluding the false fronts) cut a 1/2\" wide and 1/4\" deep dado to house the drawer bottoms",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b3d00b39a404438f.webp"
    },
    {
      "title": "Assemble Drawer Boxes",
      "body": "Assemble all 4 drawer boxes using 1\" long pocket hole screws",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2823c4f50d5729d4.webp"
    },
    {
      "title": "Install Drawer Slides",
      "body": "Using a small spacer, install 4 sets of drawer slides inside the case",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/08e3fbd147fd2230.webp"
    },
    {
      "title": "Install Large Drawers",
      "body": "Install large drawers between the drawer slides, attach the drawer front, and attach the drawer pull",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/002c2402e5662720.webp"
    },
    {
      "title": "Install Small Drawers",
      "body": "Install small drawers between the drawer slides, attach the drawer front, and attach the drawer pull",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/dc91c436a8f82d1a.webp"
    },
    {
      "title": "You Are Done!",
      "body": "Congrats on building the under workbench storage!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4836c71d0f462746.webp"
    }
  ],
