  "steps": [
    {
      "title": "Construct the base",
      "body": "If you have not already constructed the CAT LITTER BOX CABINET..... see plan and construct the base",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/12f0aca9858b53fe.webp"
    },
    {
      "title": "Cut the side panels",
      "body": "Cut (2) side panels to the dimensions shown out of 1x12 material cut down to 9 3/4\"",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/154fd2188ae3ba7e.webp"
    },
    {
      "title": "Cut the back panel pieces",
      "body": "Cut the back panel pieces from 1x4 material. Drill (2) pocket holes in each end of the horizontal pieces and join to the vertical pieces with 1 1/4\" pocket hole screws. Also route a 1/4\" rabbet along the inside edge of each piece to accept the plywood/beadboard in the next step",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1a66ac514a0bd546.webp"
    },
    {
      "title": "Cut the shelves",
      "body": "Cut (3) shelves to the dimensions shown out of 1x12 material cut down to 9 3/4\". Also drill three pocket holes on the bottom in each end of each shelf and connect to the side panels with two 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1152f56fe34e9cee.webp"
    },
    {
      "title": "Attach the back panel",
      "body": "Attach the back panel to the shelves and side panels by gluing and nailing with your nail gun",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/91f9ef023305103c.webp"
    },
    {
      "title": "View of assembly from the front",
      "body": "View of the assembly from the front",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/442f5a01afe6a3dd.webp"
    },
    {
      "title": "Construct the face frame",
      "body": "Construct the face from following the dimensions shown using 1x2 material cut off of the 1x12's used for shelving and side panels. Join the parts by drilling pocket holes and using 1 1/4\" pocket holes on the back side of the parts. Install the face frame to the shelf box by gluing and using your nail gun",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/81b34cea3651e0d2.webp"
    },
    {
      "title": "Attach the crown",
      "body": "Cut crown trim pieces per dimensions shown out of 1x2 material. Add crown trim to the assembly using your nail gun.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e1244ab8c9a9b739.webp"
    },
    {
      "title": "Finish",
      "body": "Finish the book shelf by painting or staining based on the materials you used.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f43ff1f57e4ebbb4.webp"
    },
    {
      "title": "Install the beadboad/plywood",
      "body": "Install beadboard or plywood into the back panel assembly",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9f62f1aae2207df4.webp"
    }
  ],
