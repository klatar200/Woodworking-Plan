  "steps": [
    {
      "title": "Assemble Sides",
      "body": "Assemble the sides by drilling pocket holes and attaching using 2-1/2\" pocket screws. Drill extra pocket holes at the top for 1-1/2\" long pocket screws. These will be used to attach the cap.\nNote: You can download a printable PDF of the plans in the \"extras\" tab",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1cf91bc041ce1550.webp"
    },
    {
      "title": "Assemble Box",
      "body": "Assemble the box by drilling pocket holes and attaching using 2-1/2\" blue-kote pocket screws. Drill extra pocket holes at the top for 1-1/2\" long pocket screws. These will be used to attach the cap.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f7634039e5bf7c8e.webp"
    },
    {
      "title": "Install Supports",
      "body": "Install the supports by first drilling pocket holes in each end and attaching using 2-1/2\" blue-kote pocket screws and 2\" exterior wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1574049c97fc2b50.webp"
    },
    {
      "title": "Install Planter Base",
      "body": "Pre-drill and install planter base using 1-5/8” exterior wood screws. Space boards approximately 3/4” apart. (Spacing is just to allow for drainage and not crucial) Staple plastic to the sides, then overlap weed barrier and staple it to the bottom to retain the soil but allow for drainage.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c020d7de34c135ad.webp"
    },
    {
      "title": "Assemble Cap",
      "body": "Drill pocket holes and assemble the cap using 1-1/2” blue-kote pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1cdec30cb22d14e7.webp"
    },
    {
      "title": "Attach the Cap",
      "body": "Use existing pocket holes to attach cap with 1-1/2” blue-kote pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1d4f2d2882303ba8.webp"
    }
  ],
