  "steps": [
    {
      "title": "Attach Bottom Shelf",
      "body": "Drill pocket holes in the short ends of each of the shelves. Attach one shelf to the ends of the front and back flush with the bottom edge.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fee353c5f30f380d.webp"
    },
    {
      "title": "Attach Shelves",
      "body": "Attach the other two shelves the same way with 11\" of space in between.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/751a8aa22acf079b.webp"
    },
    {
      "title": "Attach Trim",
      "body": "Attach the trim pieces on the outside edge of the top of each shelf using wood glue and clamps.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5283867572f6f14c.webp"
    },
    {
      "title": "Attach Casters",
      "body": "Attach the casters onto the underside of the bottom shelf. We attached ours to the end.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/87b0ab1acba9819f.webp"
    },
    {
      "title": "Attach Handle",
      "body": "Attach the handle approximately 5\" down from the top of the front.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/dbb9a43992d08aaa.webp"
    },
    {
      "title": "Enjoy!",
      "body": "Enjoy your handiwork and tag @CharlestonCrafted on Instagram with a picture!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/947331e516448cfa.webp"
    }
  ],
