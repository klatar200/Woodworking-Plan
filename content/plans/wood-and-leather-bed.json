  "cutList": [],
  "steps": [
    {
      "title": "Dimensions",
      "body": "This fits a full size mattress (75 x 54).",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f0ea32b5ecf833f9.webp"
    },
    {
      "title": "Step 1",
      "body": "Make the headboard frame. Attach the cross supports to the legs as indicated using 2 ½\" pocket hole screws. Keep all cross boards flush to front of 4x4 post legs.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6b6bb5ebd6212165.webp"
    },
    {
      "title": "Step 2",
      "body": "Attach plywood backing to cross supports using 1 ¼\" countersunk wood screws. Keep flush to lower cross support.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0a2cfdce5fb0ae88.webp"
    },
    {
      "title": "Step 3",
      "body": "Attach vertical headboard backing supports using 2\" countersunk wood screws and pocket holes at sides.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9e583a0b9c6789a2.webp"
    },
    {
      "title": "Step 4",
      "body": "Make footboard by attaching 2x8 to posts using 2 ½\" pocket hole screws. Center 2x8 on post keeping 1\" inset at both front and back.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/59528bdffb11acc3.webp"
    },
    {
      "title": "Step 5",
      "body": "Assemble the bed frame using surface mounted bed rail brackets.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/56b40676d9e98019.webp"
    },
    {
      "title": "Step 6",
      "body": "Attach long mattress supports to side rails keeping 2\" clearance above. Use 2 ½\" countersunk wood screws from the interior. Install center 2x3 mattress support using center bed rail hardware.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/71554f9bb6656cbb.webp"
    },
    {
      "title": "Step 7",
      "body": "Attach the mattress slats using 1 ¼\" countersunk wood screws. Keep even spacing about 1 ½\" between slats.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5aad624a4b63eb19.webp"
    }
  ],
