  "steps": [
    {
      "title": "Cut sides and shelves",
      "body": "Use 1x6 board - Cut 2 shelves @ 22\" Cut 2 sides @ 20\" Make pocket holes as shown in picture",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c6da1781d3410904.webp"
    },
    {
      "title": "Join shelves and sides",
      "body": "Attach the shelves to the sides at 2″ from the bottom and 5.5″ from the top using glue and pocket hole screws. Ensure that the pocket holes for the top are on the outside os the side boards.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a28acba07452fed1.webp"
    },
    {
      "title": "Add bar for books",
      "body": "attach 1x2 @ 22\" to the front leaving a 3/4\" gap on the bottom. I used a scrap 1 x3 board for the spacing.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e57c8ed25420d608.webp"
    },
    {
      "title": "Attach back of book storage",
      "body": "Attach the 1/4\" plywood cut at 23.5″ x 18″ on the back between the two shelves to create a backing for the book storage area. Use glue and finish nails",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c7a76767c1fc0fc2.webp"
    },
    {
      "title": "Attach table top",
      "body": "Attach 1 x 8 cut at 25.5\" as the table top using the pocket hole screws. Leave an inch over hang on all four sides.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3eb2b5a3c4be3dd9.webp"
    },
    {
      "title": "Finish the bedside table",
      "body": "Fill all the holes with wood putty, sand, prime and paint the table. I also added a pattern on the top to make it a little colorful.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0abcc14f973792f2.webp"
    }
  ],
