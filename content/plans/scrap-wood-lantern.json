  "cutList": [],
  "steps": [
    {
      "title": "Step 1",
      "body": "Create 2 pocket holes in each of the 2x2 corner pieces. Use the B/C slots to guide the holes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9de70160d406ec5e.webp"
    },
    {
      "title": "Step 2",
      "body": "Attach 4- 2x2 corners to each corner of the 2x8 base using wood glue and pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/898775e1ed165909.webp"
    },
    {
      "title": "Step 3",
      "body": "Measure the space between the 2x2s on each side and cut 1x2 pieces to fit at the bottom. Attach using wood glue and 2\" brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a908c3c55b0cc43e.webp"
    },
    {
      "title": "Step 4",
      "body": "Measure the space between each 2x2 at the top and cut 1x2 pieces to fit. Attach with glue and 2\" brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/00ecf3791fff43c1.webp"
    },
    {
      "title": "Step 5",
      "body": "Cut 4- 1\" sections of the remaining 1x2 to make feet for your lantern. Attach them with wood glue and 2\" brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/109d0cbdf02da2e2.webp"
    },
    {
      "title": "Step 6",
      "body": "To create the top of this lantern you can get as creative as you want. You could add a finial at the top, use a cool drawer pull you have laying around, or you could stack it with some additional wood cuts. To create the top as shown, start with a 2x6 cut to 4 1/2\"x4 3/4\". This will sit into the top opening of the lantern and prevent the lid from sliding right off. The picture shows this piece from inside the lantern. Be sure you have it positioned to fit into the opening before you attach the next piece to it.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3c24d62d8db31b42.webp"
    },
    {
      "title": "Step 7",
      "body": "Using wood glue in between, stack the 1x10 @ 8 1/4\" and then the 1x6 @ 7 1/4\" on top of the 2x6, center them and secure with 2\" brad nails through the top of the stack.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cae244f7830c3974.webp"
    },
    {
      "title": "Step 8",
      "body": "Fill the pocket holes with wood putty if desired, then stain or paint the lantern. If you will be using this lantern outside, be sure to weatherproof it with outdoor polyurethane or paint.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5b2673ac04809884.webp"
    }
  ],
