  "steps": [
    {
      "title": "Dimensions",
      "body": "40 1/8\"w x 11 1/4\"d x 36\"h",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a643fa33691314a0.webp"
    },
    {
      "title": "Step 1",
      "body": "Step 1: Build the side panel as per the diagram. Predrill pocket holes in trim pieces for later attaching to legs. Use wood glue and 1 ¼” pocket hole screws to attach top and bottom trim.\nMake 2 mirror copies.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e71d9b4d8d59be9d.webp"
    },
    {
      "title": "Step 2",
      "body": "Step 2: Attach the legs using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/570d99aec929465f.webp"
    },
    {
      "title": "Step 3",
      "body": "Step 3: Attach cross supports using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/729a91cf9a973097.webp"
    },
    {
      "title": "Step 4",
      "body": "Step 4: Attach drawer dividers using wood glue and countersunk 2” wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1acd2c90a579f47f.webp"
    },
    {
      "title": "Step 5",
      "body": "Step 5: Attach back drawer stops using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/eeb3ed66360c8a85.webp"
    },
    {
      "title": "Step 6",
      "body": "Step 6: Attach top and bottom cross supports using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/49651f7ae931019d.webp"
    },
    {
      "title": "Step 7",
      "body": "Step 7: Attach drawer guides using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a14f00e33add4a9b.webp"
    },
    {
      "title": "Step 8",
      "body": "Step 8: Attach top to frame using wood glue and 1 ¼” countersunk screws. Keep ¾” overhang on all sides except back is ¼”.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8023e056a4c9cd5e.webp"
    },
    {
      "title": "Step 9",
      "body": "Step 9: Attach backing to frame using wood glue and 1 ¼” finish nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/de5c1ea00579e6f7.webp"
    },
    {
      "title": "Step 10",
      "body": "Step 10: Make drawer boxes using wood glue and 1 ¼” finish nails. Attach drawer base using wood glue and 1 ¼” finish nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a96a2db7a1fed226.webp"
    },
    {
      "title": "Step 11",
      "body": "Step 11: Place drawer box in position and center drawer front keeping 1/16” spacing on all sides. Use wood glue and finish nails to attach then pull out drawer and attach from interior using countersunk 1 ¼” wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d9ec36b29c23756b.webp"
    }
  ],
