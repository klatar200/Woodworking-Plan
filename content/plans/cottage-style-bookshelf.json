  "steps": [
    {
      "title": "Dimensions",
      "body": "Overall dimensions: 60\"h x 36\"w x 15 3/4\"d",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7a3b02acd038a38f.webp"
    },
    {
      "title": "Step 1",
      "body": "Create the tapered end on each leg using a jigsaw or table saw.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d51b4feb1d336f4a.webp"
    },
    {
      "title": "Step 2",
      "body": "Attach the side panel cross supports using pocket holes and 1 1/4\" pocket hole screws. Make 2.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f52fdbd2ebd50afd.webp"
    },
    {
      "title": "Step 3",
      "body": "Attach the side panel into the frame using 1 1/4\" pocket hole screws. Make 2.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/01035180dc164b92.webp"
    },
    {
      "title": "Step 4",
      "body": "Attach fixed shelves to side panel using 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b5e25fee9f1fa7fc.webp"
    },
    {
      "title": "Step 5",
      "body": "Attach second side panel to other end of fixed shelves using 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/211bc4ef7a0db503.webp"
    },
    {
      "title": "Step 6",
      "body": "Attach carcass top to side panels using countersunk 2\" wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fca7071e86d8d0b3.webp"
    },
    {
      "title": "Step 7",
      "body": "Attach front trim to shelves using 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6a77e5b0f7440ed9.webp"
    },
    {
      "title": "Step 8",
      "body": "Attach top to carcass using countersunk 1 1/4\" wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/13c31e4b30ee0874.webp"
    },
    {
      "title": "Step 9",
      "body": "Make two movable shelves. Attach front trim to shelf using 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e8d8d226114b12bd.webp"
    },
    {
      "title": "Step 10",
      "body": "Attach tongue and groove backing to carcass using countersunk 1 1/4\" wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/29a69f157c3e36b0.webp"
    }
