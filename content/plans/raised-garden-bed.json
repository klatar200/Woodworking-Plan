  "steps": [
    {
      "title": "Gather Materials",
      "body": "Gather materials. Redwood or cedar are both good choices for outdoor projects. You'll need 2x4 and 2x6 boards.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0e4bc4508754913d.webp"
    },
    {
      "title": "Make Cuts",
      "body": "Use a miter saw or circular saw to make each cut according to the cut list. Feel free to modify the size as needed to best fit your needs.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/91ab8f2750aab7fd.webp"
    },
    {
      "title": "Create pocket holes",
      "body": "Use a pocket hole jig to attach the two boards that form each leg. Drill pocket holes into the 2x4 board. I'd recommend creating 4 pocket holes for each leg.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/83c1e30f605be56c.webp"
    },
    {
      "title": "Connect legs",
      "body": "Use 2 1/2 inch Kreg screws to attach the leg boards.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0c24843cb8e2e98b.webp"
    },
    {
      "title": "Layout boards",
      "body": "Layout the legs and long side boards.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c3226afe758da34f.webp"
    },
    {
      "title": "Attach side boards to legs",
      "body": "Use 2 1/2 inch wood screws to attach each 2x6 board to each leg. Use 2 screws on the end of each board.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3d40962c76e84952.webp"
    },
    {
      "title": "Prepare to add short side board",
      "body": "Here is a photo showing the two longer sections prior to adding the other 2 sections.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b5360621fe7c540a.webp"
    },
    {
      "title": "Connect short side boards",
      "body": "Use 2 1/2 inch wood screws to attach the shorter 2x6 side boards to the leg.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fdb56b1bdf9f8a44.webp"
    },
    {
      "title": "Sides added",
      "body": "Here is a photo showing the sides connected.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b2705ce814db0a33.webp"
    },
    {
      "title": "Connect the last side",
      "body": "Complete the four sided box by attaching the remaining side with 2 1/2 inch wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a9c9d2fc26f91787.webp"
    },
    {
      "title": "Create cap boards frame",
      "body": "Form the frame for the top cap out of 2x4 boards. Connect at each corner from the underside using 2 1/2 inch Kreg screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a2c91d3f0922fa70.webp"
    },
    {
      "title": "Create pocket holes",
      "body": "Drill pocket holes to enable the top caps to be connected from the underside using 2 1/2 inch Kreg screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/68673a35057d9883.webp"
    },
    {
      "title": "Add center 2x4 supports",
      "body": "Center the 2x4 middle supports on the outside of the planter and then attach with 2 1/2 inch screws from the inside.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/105f5b86860dc2d8.webp"
    },
    {
      "title": "Prior to cap",
      "body": "Here is the planter prior to the 2x4 cap frame being attached.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/db843604b324821e.webp"
    },
    {
      "title": "Attach cap from underside",
      "body": "Attach the top cap to the sidewalls from the underside using 2 1/2 inch Kreg screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/85321c9d6029cdee.webp"
    },
    {
      "title": "Level",
      "body": "Determine where the planter will go. Create a level surface.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f12a631318379a8f.webp"
    },
    {
      "title": "Weed cloth",
      "body": "Add weed cloth to prevent unwanted vegetation from growing into your planter. Use chicken wire to keep gophers out if needed.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cd2ba95a68827150.webp"
    },
    {
      "title": "Add soil",
      "body": "Add soil to the planter. It will take approximately 19 cubic feet. Plants some flowers, herbs, or vegetables!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3c0e7ec4794e3c23.webp"
    }
  ],
