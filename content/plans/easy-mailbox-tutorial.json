  "cutList": [],
  "steps": [
    {
      "title": "Plane Boards",
      "body": "Plane Boards to 1/2\"",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/dbab866ea1f5794d.webp"
    },
    {
      "title": "Rough Cut the Back, Front, and Mail Holder Back",
      "body": "Cut the 1X8 down to their rough dimensions (2 @ 17 1/4, 14 11/16, 13 9/16. Then glue and clamp them together\n\n**Tip:** Easily remove glue After 20 minutes the glue should be strong enough to hold. Take the pieces out of the clamps and scrape off the glue."
    },
    {
      "title": "Finish Cut the Back, Front, and Mail Holder Back",
      "body": "Using an track saw we cut the boards to there final dimensions.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/624515abb8a59f0d.webp"
    },
    {
      "title": "Cut Remaining Parts",
      "body": "Cut the remaining parts out of the 1x4 and 1x6.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/27fcd723515c1eec.webp"
    },
    {
      "title": "cut the 20 degree bevels on the Back, Top, and Front Brace",
      "body": "we used a table saw to cut the bevels."
    },
    {
      "title": "Glue the Sides, Bottom, and the Back",
      "body": "Using an outdoor glue, glue the sides bottom and Back together.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8dd0897e2b840977.webp"
    },
    {
      "title": "Glue on the Front Brace",
      "body": "Glue the Front Brace on, flush with the top edge of the sides."
    },
    {
      "title": "Drill pocket holes",
      "body": "Drill pocket holes in the mailbox insert sides and bottom\n\n**Tip:** pocket holes Pocket holes on the Bottom will be used to attach the Sides and pocket holes on the Sides will be to attach the Mailbox Insert to the Front",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/48b22362154c9f7d.webp"
    },
    {
      "title": "Clamp. Glue, and Screw Mailbox Insert",
      "body": "Glue the Sides to the Back and Bottom on the Mailbox Insert, screw the bottom to the sides",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/64a949804edc63fd.webp"
    },
    {
      "title": "Cutting Trim",
      "body": "we wanted to add trim to the front, you could buy this at the hardware store or make your own.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ae1b65e22acf9987.webp"
    },
    {
      "title": "Glue and Nail Trim",
      "body": "Add trim to mailbox.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4a59370c47fe88ec.webp"
    },
    {
      "title": "Sand & Paint",
      "body": "We sanded with an orbital sander, primed, and painted with an oil-based paint for maximum durability.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d9045043a15a8870.webp"
    },
    {
      "title": "Install Magnets",
      "body": "Drill holes for your rare earth magnets, and glue them in place.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cc49d80ccf07ae4f.webp"
    },
    {
      "title": "Assemble",
      "body": "Assemble mailbox!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e2d0936ce383e95a.webp"
    },
    {
      "title": "Reveal!",
      "body": "Check out the final product!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e30f611c3062b2ca.webp"
    }
  ],
