  "steps": [
    {
      "title": "Assemble Frame",
      "body": "Join both 25 1/2\" and 24\" 1x6\" boards using wood glue and 2 inch, 16 gauge finishing nails. This will form a 25 1/2\" square.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/86ab5b87b19981ab.webp"
    },
    {
      "title": "Vertical Divider",
      "body": "Insert remaining 1\"x 6\"x 24\" board centered vertically. Glue and secure using 2\" 18 gauge finish nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/baea942f32f35f1a.webp"
    },
    {
      "title": "Shelf Insert",
      "body": "Using (2) of the 1\"x 6\"x 11 3/4\" boards and the 1\"x 6\"x 7 1/2\" board, and form a \"I\". Make sure that the 7 1/2\" board is centered on both 11 3/4\" boards. Use wood glue and reinforce with 2\" 16 gauge finish nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/78538b7be5577db8.webp"
    },
    {
      "title": "Shelves",
      "body": "Insert the pre-assembled \"I\" shelf so that the base of the bottom board is 17\" from the top of the unit. On the right hand side, insert the remaining 1\"x 6\"x 11 3/4\" board. Position it so that the bottom of the board is 13\" from the top of the unit.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/14f60fb632016002.webp"
    },
    {
      "title": "Front Rails",
      "body": "Attach the 25 1/2\" 1x2\" board(s) to the face of the unit using wood glue and 2 inch 16 gauge finishing nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e44ef0ce1994e11f.webp"
    },
    {
      "title": "Back Support",
      "body": "Attach the remaining 24\" 1x2\"board using wood glue and 2 inch 16 gauge finishing nails. This is an ideal place to attach the unit to the wall, or you can attach hanging hardware to the back.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7894fe6609d53ca7.webp"
    },
    {
      "title": "Finish",
      "body": "Fill all nail holes with wood filler. Sand smooth, then apply desire stain and/or paint."
    }
  ],
