  "cutList": [],
  "steps": [
    {
      "title": "Cut Wood",
      "body": "Cut your wood to the specified dimensions.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/debc2d36dad0bbb3.webp"
    },
    {
      "title": "Drill Pocket Holes",
      "body": "Drill pocket holes as follows: 3 pocket holes along each side of your bottom piece; 2 pocket holes at each end of the bottom piece; 2 pocket holes at one end of each divider piece.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/50ba46593e16d280.webp"
    },
    {
      "title": "Drill Handle Holes",
      "body": "Use a 1\" Forstner bit to drill a hole, centered, 1/2\" inch from one end of both side pieces. This hole will accommodate your dowel rod handle.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e2e4d82b45844b74.webp"
    },
    {
      "title": "Sand",
      "body": "Sand everything smooth."
    },
    {
      "title": "Attach Sides and Dividers",
      "body": "Use 1 1/4\" pocket hole screws to attach your side pieces and dividers (evenly spaced) to your bottom piece. Make sure your 1\" holes are positioned at the top when your sides are attached.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/200e7e05f73ff71a.webp"
    },
    {
      "title": "Attach Front and Back",
      "body": "Use 1 1/4\" pocket hole screws to attach the front and back, making sure the pocket holes are facing down. It's easiest to turn the whole piece on its side when attaching these.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/652720c42c6bcc78.webp"
    },
    {
      "title": "Reinforce Front and Back",
      "body": "Use a brad nailer to secure your front and back piece to the sides.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0a9704390a79e2e8.webp"
    },
    {
      "title": "Add Handle",
      "body": "Slide your dowel rod through the holes in your side pieces, using a mallet to assist you.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4d37f18cf49339d5.webp"
    },
    {
      "title": "Stain",
      "body": "Stain your wine caddy any color you choose. This one is Special Walnut.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1b4dd8c8055aaded.webp"
    },
    {
      "title": "Add Wine",
      "body": "Add 3 bottles of your favorite wine!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e901fb427829792e.webp"
    }
  ],
