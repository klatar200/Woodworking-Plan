  "steps": [
    {
      "title": "Cut wood to size",
      "body": "Cut wood to size using miter saw. Refer to attached plans for cut list with sizes.\nSand any wood that will be painted with orbital hand sander.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5c27a371246da854.webp"
    },
    {
      "title": "Drill pocket holes",
      "body": "Using the Kreg Jig system, drill 2 pocket holes on the edges of each side piece.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c56db1398926a4db.webp"
    },
    {
      "title": "Assemble sides",
      "body": "Put sides together into box by attaching to legs. Prepaint legs before assembly if desired.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1935ff610ec7de32.webp"
    },
    {
      "title": "Add top trim",
      "body": "The trim is made from cedar that is three inches side and cut at 45 degree angles at the corners and connected with pocket holes on the underside. Prepaint the pieces black if desired and attach with staple gun from the top. Fill all holes with wood filler, sand and repaint black.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4d784d2c779b3d6d.webp"
    },
    {
      "title": "Add slats",
      "body": "The planter pots will sit directly onto the slats so it is easy to swap out seasonally. We attached the slats (1 inch pieces of cedar) 11 inches from the top of the planter.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/57a5ebebb80f0fbb.webp"
    }
  ],
