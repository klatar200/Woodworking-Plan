  "steps": [
    {
      "title": "Assemble Frame",
      "body": "Drill the Kreg HD pocket holes and assemble the frame using 2-1/2\" Kreg HD pocket screws.\nDownload printable PDF in extras tab.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b4d4650bb3c6cf40.webp"
    },
    {
      "title": "Assemble Doors",
      "body": "Drill Kreg HD pocket holes and assemble with 2-1/2” Kreg HD pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5c34c2d1e9c69da7.webp"
    },
    {
      "title": "Assemble Lid",
      "body": "Drill Kreg HD pocket holes and assemble with 2-1/2” Kreg HD pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/952d4d3877e3f519.webp"
    },
    {
      "title": "Final Assembly",
      "body": "Attach roofing to lid using 1” roofing screws.\nCut poultry wire to size and attach to inside of frame and doors with 3/4” poultry staples.\nShim doors for even gaps and install doors and lid with hinges and included hardware.",
