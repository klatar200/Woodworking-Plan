  "steps": [
    {
      "title": "Cut the plywood",
      "body": "Cut the basic pieces with a circular saw guided by the Kreg Straight Edge Guide.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/33b3cbc099cbeac9.webp"
    },
    {
      "title": "Cut the top",
      "body": "Cut a circle in the top with a jig saw, then cut it in half to get two panels that can go around the plant.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2eef9921e5b347ea.webp"
    },
    {
      "title": "Assemble and apply concrete",
      "body": "Screw the 1-1/2\" wide strips to the narrow side panels to make ledges for the top and base plates. Use pocket holes to attach the side panels to make a square plywood tube. Coat the entire outside with feather finish concrete mix.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5c7f041763dcd354.webp"
    }
