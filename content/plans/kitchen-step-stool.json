  "steps": [
    {
      "title": "Cut Wood",
      "body": "Cut scrap wood for the top of the stool to desired width. I made mine 16\" wide and used two pieces of leftover tongue and groove wood.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/be020281a1775332.webp"
    },
    {
      "title": "Cut wood for legs",
      "body": "Cut two pieces of 1\" x 8\" to eight inches. Bevel cut the edges to eight degrees. Drill four pocket holes into one end of each leg piece. Attach legs with pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fd0f4f2a15ddc338.webp"
    },
    {
      "title": "Attach braces",
      "body": "Bevel cut three of 1\" x 2\" to lengths necessary for braces between the legs for strength. Attach with brad nails or pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/35862eb2a884c05d.webp"
    },
    {
      "title": "Finish",
      "body": "Paint or stain!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cb454ffc1addb419.webp"
    }
  ],
