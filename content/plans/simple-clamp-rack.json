  "cutList": [],
  "steps": [
    {
      "title": "Watch Build Video",
      "body": "I highly recommend watching the full build video (linked below) to help you better understand how this project comes together. There are many aspects that are better explained through video compared to text.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8294e1ed68d6acd6.webp"
    },
    {
      "title": "Cut plywood",
      "body": "Cut all pieces according to the cutlist. Note that all of the pieces on this project are made out of ¾” plywood. Feel free to substitute thinner plywood, but ¾” thick would be your best bet to ensure stability of the clamp rack.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ce0b2f37b95f5706.webp"
    },
    {
      "title": "Cut out clamp notches",
      "body": "Referring to the downloadable plans, cut out all of the notches that are going to hold the clamps.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/aea83f8075d755b0.webp"
    },
    {
      "title": "Start to assemble clamp rack",
      "body": "Attach back panel, clamp bracket, and support bracket together with glue and screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e0bc3ae54e154c94.webp"
    },
    {
      "title": "Attach top shelf",
      "body": "Secure the top shelf to the back panel using 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cc760bf1d5067139.webp"
    },
    {
      "title": "Cut angle on side panels",
      "body": "Referring to the dimensions in the downloadable plans, cut at 30 degree angle on both side panels.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8ebe1eba2e04312d.webp"
    },
    {
      "title": "Attach side panels",
      "body": "Attach the side panels to the clamp rack assembly and you are finished!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6e5058df4bd4e066.webp"
    },
    {
      "title": "Mount to wall",
      "body": "Using appropriate wall mounting hardware, mount the clamp rack to the wall.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/248b3871d543e5d9.webp"
    },
    {
      "title": "Insert clamps",
      "body": "With the clamp rack mounted to the wall, you can now insert all of your clamps!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/22cb76279ea09ed5.webp"
    }
  ],
