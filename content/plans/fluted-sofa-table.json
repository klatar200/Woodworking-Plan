  "cutList": [],
  "steps": [
    {
      "title": "1",
      "body": "Cut wood to size. Set your pocket hole jig to 3/4” and pocket hole the top boards together using 3/4” wood glue and 3/4” screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/63c6adc3eaad6c4e.webp"
    },
    {
      "title": "2",
      "body": "Cut the legs using a track saw or table saw. Optional: Taper the legs at 5” from the bottom. Taper should be from 1.5” - 1”."
    },
    {
      "title": "3",
      "body": "Cut the apron pieces to size. Using 1 1/4” pocket hole screws, first attach the short springs to the legs and then the long aprons. Make sure to recess the apron 1/4” to make room for the dowels.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0ea5942316a15cf2.webp"
    },
    {
      "title": "4",
      "body": "Optional: roundover the legs using a router."
    },
    {
      "title": "5",
      "body": "Cut all the dowels to size. Attach to the aprons using clear CA glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f7701e43c48f9cbd.webp"
    },
    {
      "title": "6",
      "body": "Sand the top and base then stain your choice of color.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/92c88c4a6404a1e1.webp"
    },
    {
      "title": "7",
      "body": "Attach the top to the base using Z clips or figure 8 fasteners."
    },
    {
      "title": "8",
      "body": "Optional: add hardware"
    }
  ],
