  "steps": [
    {
      "title": "Dimensions",
      "body": "12\"w x 48\"l x 19\"h (with wheels)",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e7db3c7d88892228.webp"
    },
    {
      "title": "Step 1",
      "body": "Attach the short vertical supports to the longer horizontal supports using pocket holes and 2 ½” pocket hole screws.\nMake 2.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2c927502519c07ea.webp"
    },
    {
      "title": "Step 2",
      "body": "Attach long cross supports to short ends using pocket holes and 2 ½” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/32888e0d65053161.webp"
    },
    {
      "title": "Step 3",
      "body": "Attach bottom to frame using countersunk 1 ¼” wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/da74f13c52b2119f.webp"
    },
    {
      "title": "Step 4",
      "body": "Attach short sides to frame using 1 ¼” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d9ad2bb67296d7ae.webp"
    },
    {
      "title": "Step 5",
      "body": "Attach long sides to frame using 1 ¼” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/69cd002436dc84de.webp"
    },
    {
      "title": "Top",
      "body": "After attaching leather, batting and foam then attach center top underside using wood glue and 1 ¼” countersunk wood screws.\nAttach top to base using a piano hinge. Finish as desired and finally attach wheels to underside.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/62702d03012897e3.webp"
    }
  ],
