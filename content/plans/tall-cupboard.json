  "steps": [
    {
      "title": "dimensions",
      "body": "overall dimensions: 78\"h x 29 3/8\"w x 18 3/4\"d",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/362a591e803161eb.webp"
    },
    {
      "title": "step 1",
      "body": "Step 1: Build the carcass. Attach the top, middle shelf and bottom to the sides using wood glue and 1 ¼” pocket hole screws. In the top and bottom be sure to predrill pocket holes for later attaching the face frame.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/150bde710448569e.webp"
    },
    {
      "title": "step 2",
      "body": "Step 2: Construct the face frame. Attach the short trim pieces to the long trim using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/55c6330e2a2c3fb7.webp"
    },
    {
      "title": "step 3",
      "body": "Step 3: Attach face frame to carcass using predrilled pocket holes. Use wood glue and 1 ¼” pocket hole screws plus 1 ¼” finish nails on the sides",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6fd3d2ef7d31bfad.webp"
    },
    {
      "title": "step 4",
      "body": "Step 4: Use a jigsaw to cut decorative curved trim at bottom.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6dbd9bb1ab51d961.webp"
    },
    {
      "title": "step 5",
      "body": "Step 5: Attach the top the to carcass using wood glue and countersunk 1 ¼” wood screws. Keep top flush at back sides and ¾” overhang on front and sides.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7f0f9a3d92d7713d.webp"
    },
    {
      "title": "step 6",
      "body": "Step 6: Layout tongue and groove backing pieces. Assure equal spacing and secure using wood glue and 1 ¼” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2add223487682ec7.webp"
    },
    {
      "title": "step 7",
      "body": "Step 7: Make doors. Attach cross supports to door interior using wood glue and 1 ¼” finish nails. Check middle shelf placement before attaching middle cross support, support must be attached either above the middle shelf or below in order for door to close properly.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/03662e84e5898241.webp"
    }
  ],
