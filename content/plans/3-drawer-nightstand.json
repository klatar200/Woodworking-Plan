  "steps": [
    {
      "title": "Taper legs",
      "body": "If desired use a tapering jig to make bottom portion of legs tapered.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4d32c3803b037095.webp"
    },
    {
      "title": "Attach legs to side panels",
      "body": "Attach legs to side panels using 1 ¼” pocket hole screws. Keep side panel flush to leg at exterior.\nMake 2.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f804e7b72ead17f4.webp"
    },
    {
      "title": "Attach cross supports",
      "body": "Attach cross supports to side panel. Use wood glue and corresponding pocket hole screws. Keep pocket holes at back, top or underside when possible.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4689fc860d563ae4.webp"
    },
    {
      "title": "Attach opposite side to supports",
      "body": "Attach other side panel to cross supports, same as Step 3.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d1b2111974c4045d.webp"
    },
    {
      "title": "Attach top",
      "body": "Attach top to body using 1 ¼” pocket hole screws. Keep ¾” overhang at front and sides. Secure front and back cross supports to top using 2” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/69e06298b618dfa0.webp"
    },
    {
      "title": "Assemble large drawers",
      "body": "Attach long sides to short sides using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d8bf06ee28befe30.webp"
    },
    {
      "title": "Attach drawer bottom to large drawers",
      "body": "Attach drawer bottom to box using wood glue and ¾” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/415c5ef60a6b2815.webp"
    },
    {
      "title": "Assemble small drawer",
      "body": "Attach long sides to short sides using wood glue and 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2eb3dfdb3e0fc88a.webp"
    },
    {
      "title": "Attach drawer bottom to small drawer",
      "body": "Attach drawer bottom to box using wood glue and ¾” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f4eef43119e5eb17.webp"
    },
    {
      "title": "Attach drawer glide supports",
      "body": "Before installing drawer glides attach supports to interior side panels using wood glue and 1 ¼” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/86843168f6c46001.webp"
    },
    {
      "title": "Attach backing",
      "body": "Attach backing to cross supports using wood glue and ¾” brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e1c45125904ea3a6.webp"
    }
  ],
