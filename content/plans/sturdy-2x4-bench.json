  "steps": [
    {
      "title": "Build Bench Seat Frame",
      "body": "Drill 1 1/2'' pocket holes and attach 2x4's to 4x4 posts using 2 1/2'' pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8209641d1d4b94d3.webp"
    },
    {
      "title": "Add Planks to the Seat",
      "body": "Using deck screws, attach the seat planks to the frame. Start with the front and back planks (59\"), then work inward (66\"), leaving 1/4\" space between each board.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6c53a15b0e084f00.webp"
    },
    {
      "title": "Build Bench Back Frame",
      "body": "Cut your 2x4's (19\" & 16\") at 15 degrees (measuring on the long side of the angle). Drill 1 1/2'' pocket holes and attach with 2 1/2'' pocket hole screws to build a frame for the back rest.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1aecb1f5ad3ca916.webp"
    },
    {
      "title": "Add Planks to the Backrest",
      "body": "Using deck screws, attach the backrest planks to the frame. Start with the bottom and top planks (59\" and 66\"), then work inward, leaving 1/4\" space between each board.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c7047ff30e9aa83f.webp"
    },
    {
      "title": "Attach Backrest to the Seat",
      "body": "Using lag bolts, attach the backrest to the bench seat. Screw the bottom 2x4 of the frame to the bench seat.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8d873640adb0e539.webp"
    },
    {
      "title": "Finish Bench",
      "body": "Fill holes, sand, and paint or stain the bench. Finishing off with polyurethane.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1b72a106b923ff8e.webp"
    },
    {
      "title": "Secure Backrest",
      "body": "Using 4 inch lag screws, attach the backrest to the bench seat. Lag screws should be spaced about 10 inches apart. Screw the bottom 2x4 of the frame to the bench seat.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9047faf18b1611fc.webp"
    },
    {
      "title": "Build Seat Frame",
      "body": "Build the seat frame using pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2722090642631cd6.webp"
    }
  ],
