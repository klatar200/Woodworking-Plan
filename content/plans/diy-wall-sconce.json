  "cutList": [],
  "steps": [
    {
      "title": "Cut Your Wood",
      "body": "Cut your 1x6 boards to the specified dimensions, and cut your square dowel pieces at a 30 degree angle on each end, not parallel.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/bae3e949db030933.webp"
    },
    {
      "title": "Drill Pocket Holes",
      "body": "Drill 3 pocket holes into one end of your 9\" long 1x6 board.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/88c9a54c940bd9eb.webp"
    },
    {
      "title": "Sand",
      "body": "Sand everything smooth"
    },
    {
      "title": "Attach Boards",
      "body": "Using 1 1/4\" pocket hole screws, attach your 9\" long board to your 6\" long board.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2beace38c433a764.webp"
    },
    {
      "title": "Create Triangles",
      "body": "Using wood glue, attach your dowel pieces and then use painter's tape to hold them in place while the glue dries. When the glue has dried, use a crown stapler to secure and reinforce the pieces, placing one staple at each joint.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c9a960a47b226c66.webp"
    },
    {
      "title": "Attach Triangles to Sconce",
      "body": "Using wood glue, attach your triangles to the top and bottom of the sconce and then secure with painter's tape to hold them in place until the glue dries.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/36f91a9479fafc39.webp"
    },
    {
      "title": "Stain",
      "body": "Stain (or paint) your sconce in the color of your choice. I used a Provincial stain for this one.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/21390158225820e4.webp"
    },
    {
      "title": "Add Spray Paint Detail (Optional)",
      "body": "Measure and tape 2\" in from the top and bottom. Cover the middle section of the sconce with plastic to protect it, and then spray paint the exposed parts. Remove tape while paint is still damp.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2c16f89559d56197.webp"
    },
    {
      "title": "Add Hanging Hardware",
      "body": "Attach keyhole hanger using the screws that come with it. I positioned mine about an inch from the top, centered.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6fd0b55b2f12dea7.webp"
    }
  ],
