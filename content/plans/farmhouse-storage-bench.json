  "steps": [
    {
      "title": "Assemble the legs",
      "body": "Drill 1 1/2\" pocket holes into the four stretchers for each side of the bench. Attach with wood glue and 2 1/2\" pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/43b4eb4fefb41f49.webp"
    },
    {
      "title": "Attach the lower stretcher",
      "body": "Drill 1 1/2\" pocket holes into the lower 2x4 stretcher. Center it between the legs and attach with wood glue and 2 1/2\" pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1d4bc4b6ddf16bb2.webp"
    },
    {
      "title": "Add the aprons",
      "body": "Attach the 1x4 aprons to the front and back edges of the legs, flush with the top. Drill 3/4\" pocket holes into each end and attach with wood glue and 1 1/4\" pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/205132c41b217466.webp"
    },
    {
      "title": "Attach the plywood bottom",
      "body": "Drill 1/2\" pocket holes into the 1/2 plywood that will make up the storage compartment bottom. Attach flush with the bottom edge of the 1x4 and 2x4 frame pieces with 1\" pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9dfbe1c700fb37dc.webp"
    },
    {
      "title": "Build the bench seat",
      "body": "Use a table saw or the adaptive cutting system to rip two 1x8 boards down to 6 5/8\" widths. Cut to size and drill 3/4\" pocket holes into the three long boards as well as the breadboard ends. Attach together with wood glue and 1 1/4\" pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c263f37399c8652c.webp"
    },
    {
      "title": "Sand and finish",
      "body": "Sand the entire project down to 220 grit with an orbital sander or by hand. Finish as desired with paint or stain."
    },
    {
      "title": "Attach the bench seat",
      "body": "Using 2 1/2\" middle hinges, attach the bench seat to the base. Mark the location of the hinges and trace the outside edges with a pencil into the top of the base. Using a chisel and mallet, make a mortise into the wood deep enough for the hinges to fit into and the bench seat to sit flush with the top of the base (approx 1/8\").",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d5dc16d3521a2a9e.webp"
    }
  ],
