  "steps": [
    {
      "title": "Cut dados for shelves",
      "body": "Cut five 1/4\" dados, 1\" apart, on the top half of the vertical supports. Two of the vertical supports should have dados on both sides.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a4b1845b3436310f.webp"
    },
    {
      "title": "Drill pocket holes",
      "body": "Drill pocket holes at the bottom of each vertical support on the same side as the dados.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a364e256b1499c4a.webp"
    },
    {
      "title": "Attach vertical supports to bottom",
      "body": "Attach the vertical supports to the bottom piece with 1 1/4\" screws. The vertical supports should be spaced 6 1/4\" apart.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/4da3938ac36f3773.webp"
    },
    {
      "title": "Nail top in place",
      "body": "Nail the top of the box in place through the vertical supports.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2301c5875f717885.webp"
    },
    {
      "title": "Nail back in place",
      "body": "Nail the back of the box in place.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/fea4e0df37a5b0fa.webp"
    },
    {
      "title": "Slide shelves in place",
      "body": "Slide each of the 1/4\" plywood shelves in place. If they have trouble fitting, sand the top and bottom until it moves freely.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/08ebe2dfea7e315c.webp"
    },
    {
      "title": "Label sandpaper grits",
      "body": "Don't forget to label each shelf with the grit number. Now you can easily see when you're running low on your favorites!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/18531f1078fd34cc.webp"
    }
  ],
