  "steps": [
    {
      "title": "Assemble Leg 1",
      "body": "Use 1 ½ pocket holes underneath 2x4 (12 3/8) to join together 2x4 legs.\nUse 2 ½ pocket screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d12b157822a7ec2f.webp"
    },
    {
      "title": "Assemble Leg 2",
      "body": "Repeat step 1 to make the second leg",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7647ef3caeb831ac.webp"
    },
    {
      "title": "Add Bottom Braces",
      "body": "Add bottom braces to legs with 1 ½ pocket holes under 2x4 (white) using 2 ½ pocket screws",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/836ed7c5cd210f6f.webp"
    },
    {
      "title": "Add Bottom Seating",
      "body": "Add 1x6 to legs using 2” screws. 1x6 should hang off the edge of the legs by a ½ inch. 1x6 should be flush with back.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5d77b59433d55e53.webp"
    },
    {
      "title": "Add Additional Seating",
      "body": "Add the additional 1x6’s using 2”screws and leave 1/8 of space in between each piece.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a90cb5723f498433.webp"
    },
    {
      "title": "Add Back Seating",
      "body": "Add 1x6’s to the back using 2”screws leaving 7/8 of space in between.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5921a9c1f801354a.webp"
    },
    {
      "title": "Add Side Under Seating",
      "body": "Add 1x4’s on the sides of the bench with 2” screws into the 2x4 legs.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a978054d3ea10d84.webp"
    },
    {
      "title": "Add Front Under Seating",
      "body": "Add the front 1x4 under the seat using 2” screws into the 2x4 legs.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/edc6e3359ef0bb86.webp"
    },
    {
