  "steps": [
    {
      "title": "Dimensions",
      "body": "Overall dimensions 66\"w x 22 1/2\"d x 28\"h",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6d9e789c99e47cae.webp"
    },
    {
      "title": "Step 1: top",
      "body": "Attach the top boards using wood glue, pocket holes and 1 1/4\" pocket hole screws. Keep boards flush to form one smooth surface. Once all boards are attached measure the width to confirm 22 1/2\" before cutting plywood sheets for remaining steps as 1x5 boards can vary in width.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9642a16e5803a174.webp"
    },
    {
      "title": "Step 2: sides",
      "body": "Attach sides to underside of top using wood glue, pocket holes and 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e07d442286a0ff69.webp"
    },
    {
      "title": "Step 3: cubby shelf",
      "body": "Attach cubby shelf to sides using wood glue, pocket holes and 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b913b0d6ab621cb7.webp"
    },
    {
      "title": "Step 4: cubby dividers",
      "body": "Attach cubby dividers using countersunk 2\" wood screws from underneath and 2\" finish nails from the top.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ea4d1e945f90449d.webp"
    },
    {
      "title": "Step 5: drawer dividers",
      "body": "Attach drawer dividers to shelf using wood glue, pocket holes and 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d1069608ba79e39e.webp"
    },
    {
      "title": "Step 6: drawer supports",
      "body": "Attach drawer supports using wood glue, pocket holes and 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3db74a935cf40759.webp"
    },
    {
      "title": "Step 7: drawer box",
      "body": "Construct drawer box using wood glue, pocket holes and 1 1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/352cf9705140a0b9.webp"
    },
    {
      "title": "Step 8: drawer base",
      "body": "Attach base to drawer using wood glue and countersunk 1 1/4\" screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b4a7599076c969e1.webp"
    },
    {
      "title": "Step 9: drawer front",
      "body": "Cut out drawer front handle pull as per sketch.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a2ca6bdbd193311e.webp"
    },
    {
      "title": "Step 10: drawer front",
      "body": "Attach drawer glides as per hardware instructions. Put drawer front in place with wood glue and finish nails then remove drawer and secure front to box using countersunk 1 1/4\" wood screws from interior.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/78b4ab68c80e6b07.webp"
    },
    {
      "title": "Step 11: backing",
      "body": "Attach backing to unit using wood glue and 3/4\" finish nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/258b928147b7ec0f.webp"
    }
  ],
