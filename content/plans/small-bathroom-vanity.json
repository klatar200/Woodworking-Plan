  "steps": [
    {
      "title": "Legs and side rails",
      "body": "Build two sets of legs and side rails. Attach rails to legs as shown.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8f75bbf70776e36a.webp"
    },
    {
      "title": "Add top rails and shelf boards",
      "body": "Connect the two leg sections with the top rails. Nail on the bottom shelf boards.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5f83bad13af9117c.webp"
    },
    {
      "title": "Build two 2x3 frames",
      "body": "Build two 2x3 frames as shown for top section of vanity. Cut corners at a 45 degree miter. Attach with pocket holes and finish nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b75a17fccc386909.webp"
    },
    {
      "title": "Build 1x3 frame",
      "body": "Build a 1x3 frame as shown using 45 degree bevel cuts. Attach with wood glue and 2'' finish nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/7373234bf8792b4f.webp"
    },
    {
      "title": "Attach top 2x3 frame to 1x3 frame",
      "body": "Using 3/4'' pocket holes and 1 1/4'' pocket hole screws attach the 1x3 frame to the 2x3 top frame as pictured.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/9980fed9dfbb3ade.webp"
    },
    {
      "title": "Attach bottom 2x3 frame",
      "body": "Attach the bottom 2x3 frame to the 1x3 frame with 2 1/2'' or 3'' screws, make sure to pre-drill first.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/20e568173a70c304.webp"
    },
    {
      "title": "Build top insert piece",
      "body": "For the decorative top cut your plywood and attach the 3/4'' wood to the top as pictured with wood glue and finish nails, nail from bottom. You may vary the pattern as desired.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d1a37f46bcda9db0.webp"
    },
    {
      "title": "Add insert to the top 2x3 frame",
      "body": "Drill 2 1/2'' pocket holes into the plywood side of the insert and attach it inside of the top 2x3 frame.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/91a4f457edd22ebe.webp"
    },
    {
      "title": "Attach the base to the top",
      "body": "Attach the base of your vanity to the top with 3'' screws as shown. Cut any holes into the top of the vanity for your sink with a jigsaw. Install sink according to factory directions and enjoy!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c81703e4455cede8.webp"
    },
    {
      "title": "Finished Vanity Dimensions",
      "body": "Here are the finished dimensions of the small bathroom vanity.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ffc7f7e4582e0a48.webp"
    },
    {
      "title": "Visit MyLove2Create.com",
      "body": "For more details and picture tutorial of this project visit, http://www.mylove2create.com/2016/09/small-bathroom-vanity.html"
    }
  ],
