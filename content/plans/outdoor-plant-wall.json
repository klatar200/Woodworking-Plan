  "steps": [
    {
      "title": "Cut wood",
      "body": "Cut wood down to size according to the cut list with a miter saw.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b776f8f42136124e.webp"
    },
    {
      "title": "Drill pocket holes",
      "body": "Drill pocket holes on the end of each slat (2 on each end). On one top slat and one bottom slat drill 5 pocket holes horizontally to screw into the top and bottom frame.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ddad3fdb11c11631.webp"
    },
    {
      "title": "Assemble outdoor plant wall",
      "body": "Assemble outdoor plant wall. Start by attaching all slats to one of the side pieces of the frame spacing them evenly with 1/4\" space in between each slat. Next, add the top and bottom of the frame and lastly add the other side piece of the frame. On the mitered corners of the frame, add two screws through each outside corner (4 total screws in each corner).",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/294dd66387872342.webp"
    },
    {
      "title": "Sand",
      "body": "Sand entire structure lightly with orbital sander starting with 80 grit sandpaper on any uneven pieces (we had some due to warping) and working up to 150 grit sand paper.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d6c14ebaf3c05583.webp"
    },
    {
      "title": "Prime",
      "body": "Roll on primer onto entire structure.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6aed0a1b9e51f809.webp"
    },
    {
      "title": "Paint",
      "body": "Paint entire structure with exterior paint. We used a paint sprayer, which made it easy to get into the cracks and corners.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a22db508fdda5bf3.webp"
    },
    {
      "title": "Add Planter Hooks",
      "body": "Mark spaces for 9 planters so they are evenly spaced on your plant wall and attach the planter pot hooks.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/93da8de75bc8580d.webp"
    },
    {
      "title": "Plant Succulents",
      "body": "Plant your succulents in terra cotta planters with cactus soil, Perlite and succulent rock mix to provide adequate drainage.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e8cad6e70814265c.webp"
    },
    {
      "title": "Hang plant wall",
      "body": "Hang plant wall on your wall. Our exterior is brick, so we drilled two angled holes at the correct height and added steel rods and secured with 100% silicone. The plant wall hangs directly onto the steel rods.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f72aad5b2bc21a73.webp"
    }
  ],
