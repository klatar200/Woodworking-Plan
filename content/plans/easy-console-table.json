  "steps": [
    {
      "title": "Build Leg Supports",
      "body": "Attach the 11.5” pieces to the 29” pieces to form a box. (11.5”pieces go inside of 29” pieces. Repeat for both legs of the table.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/412d89f45fa31aa2.webp"
    },
    {
      "title": "Attach Table Top Supports",
      "body": "With legs facing each other, attach middle 35” braces to the tops of the front and back (braces are placed Inside of table legs components).",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/59128c771e853b46.webp"
    },
    {
      "title": "Assemble Table Top",
      "body": "With pocket hole screws, screw the 3 1x6x4 boards together to form the top of the table.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/45569d3d039ad61f.webp"
    },
    {
      "title": "Attach Table Top",
      "body": "Attach the top to the table legs with 2” wood screws through the bottom of the leg assembly.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/bb9dfdddcbcc8055.webp"
    },
    {
      "title": "Finishing",
      "body": "Sand your table, stain with color of choice, and enjoy your build!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c0ca8894c0c5e704.webp"
    }
  ],
