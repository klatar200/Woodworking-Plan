  "steps": [
    {
      "title": "Assemble Toy Cart Bottom",
      "body": "Begin assembling the bottom of the toy cart by attaching the two side 1x4s to the bottom plywood piece using a kreg jig on a 3/4\" setting and 1 1/4\" pocket hole screws and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f3dea09470e3e8bd.webp"
    },
    {
      "title": "Finish Toy Cart Bottom Assembly",
      "body": "Attach the front and end 1x4 trim pieces to the asembled toy cart bottom using a kreg jig on a 3/4\" using 1 1/4\" pocket hole screws and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6178be4f5a93a2be.webp"
    },
    {
      "title": "Attach Back Slats",
      "body": "Using a brad nailer and wood glue, attach three slates to the back of the assembled toy cart bottom. Outside slates should be inset by a 1/2\"",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/31cbdaabb38659c4.webp"
    },
    {
      "title": "Attach Horizontal Slates",
      "body": "Attach the back horizontal slates to the back vertical slates using a brad nailer and wood glue",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/703552ca915189c2.webp"
    },
    {
      "title": "Attach Side Slates",
      "body": "Attach the two vertical slates to boths side of the assembled toy cart bottom using brad nailers and wood glue and then add on the horizontal slates. The two vertical slates should be inset 2\"",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2d959527e5d02056.webp"
    },
    {
      "title": "Attach Casters/Hardware",
      "body": "Attach casters to toy cart and add hardware as needed.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/6a4e77a727b99229.webp"
    },
    {
      "title": "Visit Handmade-Haven.com",
      "body": "Visit https://www.handmade-haven.com/blogs/news/diy-toy-cart for finish details.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/48a57d1b0b792b28.webp"
    }
