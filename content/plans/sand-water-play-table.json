  "steps": [
    {
      "title": "Build the Box",
      "body": "Drill 3/4\" pocket holes as shown and construct the box with 1-1/4\" pocket hole screws and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/942033e06498a68f.webp"
    },
    {
      "title": "Add the Slats",
      "body": "Drill 3/4\" pocket holes into the 1x2 support slats and attach to the box with 1-1/4\" pocket hole screws and wood glue. Space the slats approximately 4-1/4\" apart.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/07c6e816b7fa2d09.webp"
    },
    {
      "title": "Attach the Divider",
      "body": "Drill 3/4\" pocket holes into 1x6 divider and attach as shown with 1-1/4\" pocket hole screws and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5c976f00325ba361.webp"
    },
    {
      "title": "Add the Legs",
      "body": "Pre-drill pilot holes and drive 1-1/4\" wood screws to attach the legs to the box as shown.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/50ad2eb159687dd4.webp"
    },
    {
      "title": "Construct the Bottom Shelf",
      "body": "Drill 3/4\" pocket holes and construct the bottom shelf as shown with 1-1/4\" pocket hole screws and wood glue. Space slats approximately 1-1/2\" apart.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3a4d454ac48bd5f2.webp"
    },
    {
      "title": "Attach the Bottom Shelf",
      "body": "Attach the bottom shelf with 1-1/4\" pocket hole screws. The bottom shelf is 2\" from the ground.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0b0ea17e5d62e1b7.webp"
    },
    {
      "title": "Attach the Top",
      "body": "Install hinges to attach the top to the play table. Note: torsion hinges are recommended to keep the lid from slamming down on tiny fingers.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/edf794a772f3e4dc.webp"
    },
    {
      "title": "Add Trim",
      "body": "Attach 1x2 trim to the top with 1-1/4\" brad nails and wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/03d9a47d39d01917.webp"
    },
    {
      "title": "Visit JenWoodhouse.com",
      "body": "For more DIY project ideas and free building plans, please visit JenWoodhouse.com",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b4d13b47471a77f5.webp"
    },
    {
      "title": "Sand, Stain/Paint, and Finish",
      "body": "Sand, stain or paint, and finish with an exterior-grade top coat as desired. Because plywood is not suitable for outdoor use, I recommend storing the play table in a garage or under a covered area when not in use to protect it from outdoor elements.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/3cabc94bfb7b4e4e.webp"
    }
  ],
