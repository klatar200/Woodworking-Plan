  "steps": [
    {
      "title": "Cut pieces",
      "body": "Using 1x12 lumber of choice (actual size 3/4\" x 11 1/4\"), cut 3 pieces into 4' lengths and 2 pieces into 11 1/4\" x 10 1/2\"\nAlso cut as many shelves as you'd like at 11 1/4\" x 10 1/2\"",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/06ff394c6e66d09b.webp"
    },
    {
      "title": "Pocket holes and shelf pin holes",
      "body": "Add 12 pocket holes to one of the 4' pieces and 8 pocket holes to each of the 10 1/2\" pieces, then add shelf pin holes to the other two 4' pieces.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8a765111a7ccf44d.webp"
    },
    {
      "title": "Attach sides",
      "body": "Attach the two 4' sides of the shelf using the pocket holes, keeping holes on the back of the shelf.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/432286fa90f98e5e.webp"
    },
    {
      "title": "Attach top and bottom",
      "body": "Using pocket holes, attach the top and bottom pieces, ensuring pocket holes remain on the outside.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/16a857b749183a65.webp"
    },
    {
      "title": "Add shelves",
      "body": "Using shelf pins, attach shelving wherever you'd like and enjoy your new storage system!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b2cf26d7be224cd9.webp"
    }
  ],
