  "steps": [
    {
      "title": "Cut shelves",
      "body": "Cut two shelves. Cut one shelf from a 6' 1x12 at 38 1/2\" long and the other shelf from a 4' 1x12 at 38 1/@\" long. Drill (3) pocket holes in each end of each shelf for 1 1/4\" pocket hole screws",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/30624eb0ca08a5cd.webp"
    },
    {
      "title": "Cut end panels",
      "body": "Cut two end panels from the remainder of the 6' 1x12. Cut each end panel 15\" long",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/52ea64fde8d38481.webp"
    },
    {
      "title": "Assemble the unit",
      "body": "Assemble the shelves and end panels by using (3) 1 1/4\" Kreg pocket hole screws in each end of each shelf.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/d4d33060699e0b41.webp"
    },
    {
      "title": "Finish",
      "body": "Fill pocket holes and finish by painting or staining.....your preference."
    }
