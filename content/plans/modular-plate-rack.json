  "steps": [
    {
      "title": "Frame",
      "body": "Join both 25 1/2\" and 24\" 1x6\" boards using wood glue and 2 inch, 16 gauge finishing nails. This will form a 25 1/2\" square. Insert remaining 24\" 1x6\" board so that the bottom of the board is 12\" from the top of the unit. Then secure using glue and 2\" 16 gauge finishing nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/ad5519fb5033b5fa.webp"
    },
    {
      "title": "Front Rails",
      "body": "Attach the 25 1/2\" 1x2\" board(s) to the face of the unit using wood glue and 2 inch 16 gauge finishing nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cdba6bf6916a57af.webp"
    },
    {
      "title": "Back Support",
      "body": "Attach the remaining 24\" 1x2\"board using wood glue and 2 inch 16 gauge finishing nails. This is an ideal place to attach the unit to the wall, or you can attach hanging hardware to the back.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/06793c166012359a.webp"
    },
    {
      "title": "Finish",
      "body": "Fill all nail holes with wood filler. Sand smooth, then apply desire stain and/or paint."
    }
  ],
