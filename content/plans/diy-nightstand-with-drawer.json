  "steps": [
    {
      "title": "Step 1",
      "body": "Drill pocket holes and assemble base with 1-1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f3e95d24e78bff2d.webp"
    },
    {
      "title": "Step 2",
      "body": "Attach 1x2s to top using wood glue and 1-1/4\" brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/79bcc3c31f66e4d0.webp"
    },
    {
      "title": "Step 3",
      "body": "Attach base to top with 1-1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2c6d96ded2af1c66.webp"
    },
    {
      "title": "Step 4",
      "body": "Attach slide out support using wood glue and 1-1/4\" brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cb0e4800521b4cd7.webp"
    },
    {
      "title": "Step 5",
      "body": "Insert slide out and attach stop with 1-1/4\" wood screws. If desired, cut hole in top and back for flush mount outlets.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8a276d924b5afc51.webp"
    },
    {
      "title": "Step 6",
      "body": "Drill pocket holes and assemble drawer box with wood glue, 1-1/4\" pocket hole screws and 1-1/4\" brad nails.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/cacbaa1a73a88c0c.webp"
    },
    {
      "title": "Step 7",
      "body": "Install drawer using 16\" drawer slides and included hardware. The Kreg drawer slide jig will help with installation.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/dca0d1a072f839f9.webp"
    },
    {
      "title": "Step 8",
      "body": "Install drawer front and pulls as desired. Pull for slide out will require a 8-32 x1\" hanger bolt. Finished!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/bbd7704f825f1cfd.webp"
    }
