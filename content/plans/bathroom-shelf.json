  "steps": [
    {
      "title": "Cut the Sides",
      "body": "Using a jigsaw, cut the two sides as shown and drill 3/4\" posterior-facing pocket holes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e66d6363aade4721.webp"
    },
    {
      "title": "Attach the Back",
      "body": "Attach the back to the sides with 1-1/4\" pocket hole screws. You may opt to drill 3/4\" pocket holes into the 1x6 and 1x12 back boards and join them together with 1-1/4\" pocket hole screws before attaching the sides.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/24f01635ff740e55.webp"
    },
    {
      "title": "Attach the Bottom",
      "body": "Drill 3/4\" pocket holes into the bottom board and attach it to the carcass with 1-1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c3a14c664fa7e112.webp"
    },
    {
      "title": "Attach the Divider",
      "body": "Drill 3/4\" pocket holes into the divider and attach it to the shelf with 1-1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b501d14c1fef15fd.webp"
    },
    {
      "title": "Attach the Top",
      "body": "Drill 3/4\" pocket holes into the top and attach it to the shelf with 1-1/4\" pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/bc10ad58a05d63e0.webp"
    },
    {
      "title": "Construct and attach the top",
      "body": "Drill 3/4\" pocket holes into the 1x12 board and attach the 1x2 board with 1-1/4\" pocket hole screws. Pre-drill and countersink pilot holes into the top and attach it to the shelf with 1-1/4\" wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2f25560089e63821.webp"
    },
    {
      "title": "Attach Robe Hooks",
      "body": "Attach robe hooks as shown. Fill pocket holes with wood filler or pocket hole plugs, sand, and finish as desired. To hang the shelf on the wall, drive 2-1/2\" wood screws from the inside the shelf into the wall studs.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b5d36680d8cb5061.webp"
    },
    {
      "title": "Visit JenWoodhouse.com",
      "body": "For more free building plans and DIY project ideas, visit www.JenWoodhouse.com",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f8cff0b3b4b359a7.webp"
    }
  ],
