  "cutList": [],
  "steps": [
    {
      "title": "Dimensions",
      "body": "Overall dimensions 66 3/4h x 7 1/4\" x 7 1/4\"",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0751d727a42cdb71.webp"
    },
    {
      "title": "Step 1",
      "body": "Starting 2” from the end attach one pocket hole jig at center using the face frame clamp and drill a pocket hole. To make the next pocket hole line up the jig using the edge of the first hole as a guide. This will ensure about ¾” spacing between pocket holes. Repeat this process until you have 25 pocket holes.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/08de31a81cf58edb.webp"
    },
    {
      "title": "Step 1 IRL",
      "body": "Step 1 IRL",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/bae8bd4aab233583.webp"
    },
    {
      "title": "Step 2",
      "body": "Attach post to base 3 at center using wood glue and at least 2 – 2 ½” countersunk wood screws. Considering predrilling so the post doesn’t split.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/f66ec29b76dafc39.webp"
    },
    {
      "title": "Step 3",
      "body": "Prepare the remaining base 1 and base 2 pieces by attaching the smaller base 2 to the larger base 1 using wood glue and 2 ½” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e3e0997f1524ce0b.webp"
    },
    {
      "title": "Step 4",
      "body": "Attach the post / base 3 portion using wood glue and 1 ¼” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/2b324d53035a55ec.webp"
    },
    {
      "title": "Step 5",
      "body": "To make the circular sign at top cut out the two wood circles. Paint as desired and then attach the smaller ¼” plywood circle to the larger back circle using super glue or wood glue. Drill a 5/16” hole into the larger circle and insert the dowel using wood glue. Predrill a 5/16” hole at the top center of the post and insert the dowel with the sign.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/39f90013c7e8a9c6.webp"
    },
    {
      "title": "Step 6",
      "body": "Cut out the 4” star from ¾” thick plywood (use pattern below). Paint as desired. Predrill a 5/16” hole at center bottom and insert the 5/16” wood dowel using wood glue.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1a99306faa02ccd0.webp"
    }
  ],
