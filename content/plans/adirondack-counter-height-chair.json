  "steps": [
    {
      "title": "Dimensions",
      "body": "Overall size: 46\"h x 28\"d x 26 1/4\"w",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/0607845522ca5e2e.webp"
    },
    {
      "title": "Step 1",
      "body": "STEP 1: Attach arms to front leg using 2” countersunk screws. Make two opposing sets.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/78103fae6a3dc475.webp"
    },
    {
      "title": "Step 2",
      "body": "STEP 2: Assemble lower stretcher. Attach foot rest side rails to back stretcher using 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/5c5b661764c521c6.webp"
    },
    {
      "title": "Step 3",
      "body": "STEP 3: Attach lower stretcher to legs using 2” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a7d35d049bcc0311.webp"
    },
    {
      "title": "Step 4",
      "body": "STEP 4: Attach foot rest front apron to side rails using 1 ¼” pocket hole screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/92107d37a208d39a.webp"
    },
    {
      "title": "Step 5",
      "body": "STEP 5: Attach seat side supports to legs using 2” countersunk screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/1c4c5a5b46648449.webp"
    },
    {
      "title": "Step 6",
      "body": "STEP 6: Attach back middle support to arms using 1 ¼” pocket hole screws. Then attach to back leg using 2” countersunk wood screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/8c147364ad0a670e.webp"
    },
    {
      "title": "Step 7",
      "body": "STEP 7: Attach arm rests to arm and back middle support using 1 ¼” countersunk screws from underside.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/bd04c5e6ea734264.webp"
    },
    {
      "title": "Step 8",
      "body": "STEP 8: Attach foot rest to rails using 1 ¼” countersunk screws. Attach seat slats to supports using 1 ¼” countersunk screws.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a35fc8b7fcd37601.webp"
    },
    {
      "title": "Step 9A",
      "body": "Use a jigsaw to cut curve into back slats before assembly.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/a281ddd41af30961.webp"
    },
    {
      "title": "Step 9",
      "body": "STEP 9: Attach back slats to back bottom support using (1) 1 1/4” countersunk wood screw at center of each board.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/122ee573eea12a2e.webp"
    },
    {
      "title": "Step 10",
      "body": "STEP 10: Attach back bottom support to seat side support rails using 2” pocket hole screw. Adjust back slats to fan out and rest against back middle support. Attach to back middle support using 1 ¼” countersunk screw from front.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/142e79a8fe2e69de.webp"
    },
    {
      "title": "Step 11",
      "body": "STEP 11: Attach back top support to back slats if desired. Use 1 ¼” countersunk wood screws from front.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/83b96f383f01b22d.webp"
    }
  ],
