  "steps": [
    {
      "title": "Watch The Video",
      "body": "Watch the full build on YouTube!",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/695d2c89025ca9cc.webp"
    },
    {
      "title": "Cut the 2x6s.",
      "body": "Cut 5 pieces of 2x6 at a length of 96\".\nCut 2 pieces of 2x6 at a length of 72\".\nCut 6 pieces of 2x6 at a length of 28\".",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/c4a1fd8d64412ece.webp"
    },
    {
      "title": "Assemble the leg panels.",
      "body": "Use pocket holes to connect the pieces. I placed the holes on the inside or under side of the pieces so that they would be less visible.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/b4c37f9c0106a6be.webp"
    },
    {
      "title": "Assemble the sofa.",
      "body": "Screw the leg panels to the first four seat boards leaving 1/4\" gaps. (Used a ruler for spacing)\nScrew the angle supports to seat panels with pocket holes.\nCut notches in the last seat boards to fit around angle supports.\nScrew on back rest boards.",
      "image": "https://pub-b845b7e7b4924e4d8f2520661b54734d.r2.dev/plans/e8c682db72d8308a.webp"
    },
    {
      "title": "Seal & add cushions",
      "body": "Seal your sofa, add cushions, and enjoy!"
    }
