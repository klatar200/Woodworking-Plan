{
  "name": "@woodworking-plan/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Woodworking Plan — visual design system: token/theme system + shared UI primitives (Tailwind v4).",
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build:js": "tsup src/index.ts --format esm --dts --clean --external react --external react-dom",
    "build:css": "tailwindcss -i ./tailwind-entry.css -o ./dist/styles.css",
    "build": "npm run build:js && npm run build:css"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/react": "^19.2.17",
    "tailwindcss": "^4.3.3",
    "tsup": "^8.5.1"
  }
}
