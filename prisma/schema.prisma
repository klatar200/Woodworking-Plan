// Woodworking Plan — Prisma schema.
//
// SPRINT 0 SCOPE: this file intentionally contains NO models.
//
// The plan data model (title, category, difficulty 1-5, tools, materials,
// time estimate, cost tier, itemized cost range, instructions, images) is a
// Sprint 1 deliverable per BUILD_PLAN.md §4, and the user/account model is a
// Sprint 2 deliverable. Adding either here would be scope drift.
//
// Sprint 0 needs exactly one thing from the database: proof that the app can
// connect to Neon Postgres end to end. That is done with a raw `SELECT 1`
// health check (src/lib/db.ts), which requires a configured datasource but
// no tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
