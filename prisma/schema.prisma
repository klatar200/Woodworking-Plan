// Woodworking Plan — Prisma schema.
//
// SPRINT 1 SCOPE: the plan data model + the content ingestion path.
// Maps directly to BUSINESS_PLAN.md §4.8 (Structured Plan Data).
//
// Deliberately NOT here yet:
//   - User / account models  → Sprint 2 (Accounts & Auth, Clerk owns identity)
//   - SavedPlan / Category folders → Sprint 6
//   - Like / like counts     → Sprint 7
// Adding any of those now would be scope drift.
//
// Design notes that matter:
//   - MONEY IS STORED AS INTEGER CENTS. Never floats. A cost range of
//     $45.00–$60.00 is 4500–6000. Floats silently lose precision and this data
//     feeds a cost estimator that makers price real work against.
//   - Tools are a normalized table, not free text. BUSINESS_PLAN.md §4.6 requires
//     "only show plans I can build with tools I own" — that is impossible to do
//     reliably against free-text tool names. Sprint 5 depends on this.
//   - Time is stored as min/max MINUTES (integers) so it can be filtered and
//     sorted. A human label ("6–8 hrs", "2 weekends") is stored alongside for
//     display, because "2 weekends" is not 960 minutes of shop time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  /// POOLED connection (host contains `-pooler`). Used at runtime by the app.
  /// Vercel's serverless functions open many short-lived connections; the pooled
  /// endpoint is what survives that.
  url = env("DATABASE_URL")

  /// DIRECT connection (same host, WITHOUT `-pooler`). Used only by
  /// `prisma migrate` and `prisma db push`.
  ///
  /// Why both: Neon's pooled endpoint is PgBouncer in transaction mode, which
  /// does not support the session-level operations a migration needs (advisory
  /// locks, CREATE DATABASE for the shadow db, DDL in a session). Running
  /// migrations through the pooler fails with `P1017 Server has closed the
  /// connection` — which is exactly what happened. Prisma reads directUrl for
  /// migrations and url for everything else.
  directUrl = env("DIRECT_URL")
}

/// An application user.
///
/// SPRINT 2. Clerk is the source of truth for *identity* — credentials, sessions,
/// password resets, OAuth. This table is NOT a copy of that, and deliberately
/// stores no password, no session, and no OAuth token. It exists for one reason:
/// application data needs a stable foreign key to own rows against.
///
/// Sprints 6 and 7 (saved plans, user categories, likes) hang off this. Getting
/// it in now, keyed correctly, is what stops those sprints from bolting identity
/// on sideways.
///
/// `clerkId` is the join key and the only trustworthy identifier. It comes from a
/// verified session server-side and is never accepted from a client.
model User {
  id      String @id @default(cuid())
  /// Clerk's user id (`user_xxx`). Unique, immutable, server-derived.
  clerkId String @unique

  /// Cached from Clerk for display, so rendering a page doesn't require a
  /// round-trip to Clerk's API. Clerk remains the source of truth; these are a
  /// convenience mirror, refreshed on sign-in.
  email       String?
  displayName String?
  imageUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedPlans  SavedPlan[]
  collections Collection[]
  likes       Like[]
  reviews     Review[]
  shoppingList ShoppingListEntry[]
  tools       UserTool[]

  @@index([clerkId])
}

/// A like on a plan — BUSINESS_PLAN.md §4.7.
///
/// SPRINT 7. Same ownership rules as SavedPlan: `userId` comes ONLY from the
/// verified session, never from client input.
///
/// NOTE WHAT IS *NOT* HERE: there is no `likeCount` column on Plan.
///
/// A denormalized count would be derived data, and derived data is exactly what
/// broke production in Sprint 4 (`searchVector` shipped as an empty column) and
/// again in Sprint 6. A migration creates a column; it does not populate it. So
/// the count is computed on read via Prisma's `_count` on this relation — there
/// is nothing to backfill, and nothing that can silently drift out of step with
/// the actual likes.
///
/// The trade-off is a JOIN + COUNT on the Popular sort instead of an indexed
/// integer. At the launch catalog size (BUSINESS_PLAN.md §6: 300–500 plans) that
/// is irrelevant. If the catalog reaches a size where it isn't, THEN denormalize
/// — with a transaction that updates the count on every like/unlike, and a
/// backfill. Not before. A correct slow count beats a fast wrong one.
model Like {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  /// One like per user per plan, enforced by the DATABASE. A double-tapped like
  /// button cannot inflate the count, whatever the application layer does.
  @@unique([userId, planId])
  @@index([userId])
  @@index([planId])
}

/// A single view of a plan — Sprint 19. Feeds the Trending (7-day) and Most Viewed
/// (all-time) sorts, which are the only reason this table exists.
///
/// ═══════════════════════════════════════════════════════════════════════════════
/// NOTE WHAT IS *NOT* HERE: there is NO `userId`, and there must not be one.
///
/// A per-user view log is a BROWSING HISTORY. It is the most sensitive table this
/// app could hold, it would need a deletion path (Clerk webhook), a retention story,
/// and a privacy disclosure — and the sorts it would feed need none of it. Trending
/// and Most Viewed are COUNTS. A count does not need to know who.
///
/// Storing the id "in case we want Recently Viewed later" is the trap: adding a
/// column later is a migration, but un-collecting a year of browsing history is not
/// a thing you can do. Collect the minimum that answers the question.
///
/// It also means there is nothing here for `deleteUserByClerkId()` to clean up, and
/// nothing an attacker who reads this table learns about any individual.
/// ═══════════════════════════════════════════════════════════════════════════════
///
/// NOTE WHAT IS ALSO NOT HERE: no `viewCount` column on Plan. Same rule as Sprint 7's
/// like count — derived columns ship empty and drift (Sprints 4 and 6 both broke
/// production that way). The counts are computed on read from these rows.
model PlanView {
  id String @id @default(cuid())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  viewedAt DateTime @default(now())

  /// The Trending sort counts rows for a plan inside a time window; the composite
  /// index is what makes that an index scan instead of a table scan once this table
  /// is the largest one in the database (which it will be — it grows with traffic,
  /// not with content).
  @@index([planId, viewedAt])
  @@index([viewedAt])
}

/// A skill-building learning path — Sprint 16. BUSINESS_PLAN.md §10 (Phase 3).
///
/// An ORDERED sequence of plans that teaches something: "your first five projects",
/// "screws to dovetails". Authored content, seeded from JSON like the plans themselves,
/// so a path can be re-ordered by editing a file rather than by shipping code.
///
/// ═══════════════════════════════════════════════════════════════════════════════
/// NOTE WHAT IS *NOT* HERE — AND THIS IS THE THIRD TIME THIS FILE HAS SAID IT:
///
/// There is NO `PathProgress` model, and no `completed` column anywhere.
///
/// A step is complete when the user has REVIEWED that plan — you reviewed it, you
/// built it. Progress is COMPUTED ON READ from the `Review` table (Sprint 10), which
/// already exists and is already the truth.
///
/// A progress table would be derived state, and derived state is exactly what broke
/// production in Sprint 4 (`searchVector` shipped empty) and Sprint 6. There is nothing
/// here to backfill, nothing to keep in sync, and nothing that can silently disagree
/// with reality.
///
/// The accepted cost: someone who builds a plan without reviewing it reads as
/// incomplete. That is a real gap, and it is a fair price for having no drift.
/// ═══════════════════════════════════════════════════════════════════════════════
model Path {
  id String @id @default(cuid())

  /// The seed pipeline's upsert key. Re-seeding updates rather than duplicating.
  slug String @unique

  title String
  /// One-line hook: "From a coat rack to a bookcase, in five weekends."
  summary String
  /// Full prose intro. Markdown.
  description String

  /// Controls display order on /paths. Lower sorts first.
  sortOrder Int @default(0)

  /// Unpublished paths are invisible, exactly like unpublished plans. Same rule, same
  /// enforcement point (the data layer, never the page).
  published Boolean @default(true)

  /// QOL-E — the level of woodworker this path is FOR, on the SAME 1-5 scale as
  /// `Plan.difficulty`, rendered by the same `difficultyLabel()` (Beginner … Expert).
  /// One level vocabulary for the whole site: a filter reading "Intermediate" means the
  /// same thing on a plan and on a path (DECISIONS_LOG.md 2026-07-19).
  ///
  /// NULLABLE ON PURPOSE, and the content schema requires it anyway. A migration creates
  /// a column; it does not populate one (Sprints 4 and 6 both broke production that
  /// way), and path content only reaches production via a seed. So until that seed runs
  /// these are null, and the UI renders "not yet rated" rather than confidently showing
  /// every path as Beginner — visibly incomplete beats confidently wrong.
  experienceLevel Int?

  /// QOL-E — the category this path is about, or NULL for one that deliberately spans
  /// several ("Your First Five" walks through four different categories on purpose).
  /// An explicit field rather than a value derived from the steps: a majority-vote
  /// category would label a technique path by whichever project type happened to appear
  /// most, which is not what the path is about.
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  steps PathStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([sortOrder])
  /// QOL-E: both new fields are filterable on /paths.
  @@index([experienceLevel])
  @@index([categoryId])
}

/// One plan's place in one path.
///
/// `reason` is REQUIRED, not optional. An ordered list of plans with no explanation of
/// why each one comes where it does is not a learning path — it is a collection with a
/// number next to each item. The reason IS the teaching.
model PathStep {
  id String @id @default(cuid())

  pathId String
  path   Path   @relation(fields: [pathId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  /// 1-based. Unique within the path — two steps cannot both be "step 3".
  stepNumber Int

  /// Why this plan, here. The whole value of the feature.
  reason String

  @@unique([pathId, stepNumber])
  /// A plan appears at most once in any given path.
  @@unique([pathId, planId])
  @@index([pathId])
  @@index([planId])
}

/// A user's review of a plan — BUSINESS_PLAN.md §10, Sprint 10.
///
/// Same ownership rules as everything else in this file: `userId` comes ONLY from
/// the verified Clerk session. No function in src/lib/reviews.ts accepts a userId.
///
/// NOTE WHAT IS *NOT* HERE — AGAIN: there is no `avgRating` or `reviewCount` column
/// on Plan. Sprint 4 (`searchVector`) and Sprint 6 both broke production by adding a
/// derived column and assuming the migration would fill it. It does not. A migration
/// creates a column; it does not populate it.
///
/// So the average is computed on read with Prisma's `_avg` / `_count`. Nothing to
/// backfill, nothing that can drift away from the reviews it claims to summarize. If
/// the catalog ever grows to where a JOIN + AVG on the listing page actually hurts,
/// denormalize THEN — with a transaction and a backfill, deliberately. Not now.
///
/// One review per user per plan, enforced by the DATABASE. A double-submitted form
/// cannot produce two reviews, whatever the application layer believes.
model Review {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  /// 1–5 stars. Range is enforced in the data layer AND by a CHECK constraint added
  /// in the migration — an application-only check is one raw query away from being
  /// bypassed, and a 7-star review would poison every average silently.
  rating Int

  /// Optional prose. A star with no words is still a valid signal.
  body String?

  photos BuildPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, planId])
  @@index([userId])
  @@index([planId])
}

/// An "I made this" photo attached to a review — BUSINESS_PLAN.md §10.
///
/// Stored on Vercel Blob (DECISIONS_LOG.md 2026-07-13; Cloudflare R2 was reversed
/// because activating it requires a card on file). Only the URL lives here — the
/// bytes never touch Postgres.
///
/// `blobPath` is kept SEPARATELY from `url` on purpose: deleting a blob requires the
/// path, and parsing it back out of a public URL is the kind of thing that works
/// until the provider changes its URL format. Storing both means a delete can never
/// orphan a file (which would quietly consume the 1 GB free tier forever).
///
/// SECURITY: every byte here was re-encoded server-side and had its EXIF stripped
/// before upload. See src/lib/storage.ts — a phone photo of a workbench carries the
/// GPS coordinates of the user's home, and nobody who shares a build expects to
/// share their address.
model BuildPhoto {
  id String @id @default(cuid())

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  /// Public URL served by the blob store.
  url String
  /// Provider-side path/key. Required to DELETE the object. See above.
  blobPath String

  /// Required, not optional — consistent with `Image.alt`. An accessible feature is
  /// cheaper to build than to retrofit.
  alt String

  width  Int
  height Int

  createdAt DateTime @default(now())

  @@index([reviewId])
}

/// A bookmarked plan — BUSINESS_PLAN.md §4.3.
///
/// SPRINT 6. Every row is owned by exactly one user, and `userId` is ALWAYS
/// derived from the verified Clerk session (see src/lib/auth.ts). It is never
/// accepted from client input. If a function signature in this codebase takes a
/// `userId`, that is an IDOR bug.
///
/// `@@unique([userId, planId])` makes saving idempotent at the database level:
/// a double-tapped save button cannot produce two rows, no matter what the
/// application layer does.
model SavedPlan {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  collections CollectionPlan[]

  @@unique([userId, planId])
  @@index([userId])
  @@index([planId])
}

/// A tool the user owns — Sprint 25, "My Workshop" (BUSINESS_PLAN.md §10).
///
/// The owned-tools PROFILE, distinct from the Sprint 5 per-session tools filter (which
/// persists nothing and lives only in the URL). This is the durable inventory a
/// signed-in user declares once, so the catalog can PRE-FILL the "tools you own" filter
/// for them. It does not, and must not, silently filter results — the URL stays the
/// source of truth so a shared link renders the same catalog for everyone
/// (`DECISIONS_LOG.md` 2026-07-15).
///
/// Same ownership rules as SavedPlan/Like: `userId` comes ONLY from the verified session.
/// `@@unique([userId, toolId])` makes the set idempotent at the database level.
model UserTool {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}

/// A plan the user has explicitly put ON their shopping list — Sprint 22.
///
/// ═══════════════════════════════════════════════════════════════════════════════
/// WHY THIS IS SEPARATE FROM `SavedPlan`.
///
/// Sprint 12's shopping list was derived from EVERYTHING the user had saved. But saving
/// is "I might build this someday" and a shopping list is "I am buying materials for
/// these NOW" — two different intents, and conflating them made the list a dumping
/// ground: every idea you ever bookmarked showed up on the sheet you take to the
/// lumberyard. This model decouples them (`DECISIONS_LOG.md` 2026-07-14): a plan is on
/// the shopping list only when the user explicitly adds it.
///
/// Same ownership rules as SavedPlan/Like: `userId` comes ONLY from the verified
/// session, never from client input. `@@unique([userId, planId])` makes "add" idempotent
/// at the database level — a double-tap cannot create two rows.
/// ═══════════════════════════════════════════════════════════════════════════════
model ShoppingListEntry {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, planId])
  @@index([userId])
  @@index([planId])
}

/// A user-defined folder for organizing saved plans — BUSINESS_PLAN.md §4.4
/// ("Kitchen", "For the Cabin", "Beginner Projects").
///
/// NAMED `Collection`, NOT `Category`, on purpose. `Category` already means the
/// catalog taxonomy (cutting-boards, furniture...). Two things called Category
/// with different owners and different security rules is how someone eventually
/// writes a query against the wrong one.
///
/// NO LIMIT on how many a user may create. BUSINESS_PLAN.md §7 proposes gating
/// Free users at 1 folder, but pricing is an unconfirmed recommendation — see
/// DECISIONS_LOG.md (2026-07-13). The limit, when it comes, belongs in
/// src/lib/saves.ts and nowhere else.
model Collection {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans CollectionPlan[]

  /// Unique PER USER, not globally. Two different people may both have a
  /// "Kitchen" folder — of course they may. Scoping the constraint by user is
  /// what makes that obvious truth true.
  @@unique([userId, name])
  @@index([userId])
}

/// Membership of a saved plan in a collection. Many-to-many: a plan can live in
/// "Gifts" and "Cutting Boards" at once, which is how people actually organize.
model CollectionPlan {
  id String @id @default(cuid())

  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  savedPlanId String
  savedPlan   SavedPlan  @relation(fields: [savedPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([collectionId, savedPlanId])
  @@index([collectionId])
  @@index([savedPlanId])
}

/// Cost tier from BUSINESS_PLAN.md §4.8 — $ (cheap) through $$$$$ (expensive).
/// Kept as an enum because the 5-tier scale is a fixed product concept, not data.
enum CostTier {
  TIER_1 // $
  TIER_2 // $$
  TIER_3 // $$$
  TIER_4 // $$$$
  TIER_5 // $$$$$
}

/// A browsable catalog category (cutting boards, furniture, outdoor, storage...).
/// A table rather than an enum: the catalog will grow, and adding a category
/// should not require a schema migration.
model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  /// Controls display order in browse UI (Sprint 3). Lower sorts first.
  sortOrder   Int     @default(0)

  plans Plan[]
  /// QOL-E — learning paths ABOUT this category. Optional on the path side (a path may
  /// span categories), so this list is simply empty for a category no path focuses on.
  paths Path[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

/// A tool a plan requires. Normalized so tool-based filtering is exact.
model Tool {
  id   String @id @default(cuid())
  slug String @unique
  name String

  /// Grouping for the tool filter UI, e.g. "Power Saw", "Hand Tool", "Clamping".
  category String?

  plans PlanTool[]
  steps StepTool[]
  owners UserTool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id      String @id @default(cuid())
  /// Stable, human-readable identifier. This is the seed pipeline's upsert key —
  /// re-seeding updates the existing plan instead of creating a duplicate.
  slug    String @unique
  title   String
  /// One-line hook for catalog cards (Sprint 3).
  summary String
  /// Full prose intro. Markdown.
  description String

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  /// 1 (beginner) – 5 (advanced). BUSINESS_PLAN.md §4.6.
  difficulty Int

  /// Filterable/sortable shop time, in minutes.
  timeMinMinutes Int
  /// Human-facing label — "2 weekends" is not expressible in minutes.
  timeLabel      String
  timeMaxMinutes Int

  costTier CostTier
  /// Itemized estimated material cost range, in INTEGER CENTS.
  costMinCents Int
  costMaxCents Int

  /// Free-form keywords. Feeds keyword search (Sprint 4).
  tags String[]

  /// SPRINT 4 — full-text search index.
  ///
  /// A Postgres `tsvector` covering this plan AND its related tools and
  /// materials, because BUSINESS_PLAN.md §4.5 requires search across "titles,
  /// descriptions, tags, tools, and materials" — and tools/materials live in
  /// other tables. Denormalizing them into one indexed column is what makes a
  /// single ranked query possible instead of five joins and a manual merge.
  ///
  /// Fields are WEIGHTED (A=title, B=summary+tags, C=tools+materials, D=body),
  /// so a search for "walnut" ranks a walnut cutting board above a plan that
  /// merely mentions walnut in step 7.
  ///
  /// Prisma has no tsvector type, so it is `Unsupported` — never selected, never
  /// written through the Prisma client. It is populated by the seed pipeline
  /// (the only write path for plan content) and queried with raw SQL in
  /// src/lib/plans.ts. BUILD_PLAN.md §3 chose Postgres precisely for this.
  searchVector Unsupported("tsvector")?

  /// Unpublished plans are invisible to the catalog. Lets content be staged.
  published   Boolean   @default(true)
  publishedAt DateTime?

  tools     PlanTool[]
  materials Material[]
  cutList   CutListItem[]
  steps     Step[]
  images    Image[]
  savedBy   SavedPlan[]
  likes     Like[]
  reviews   Review[]
  pathSteps PathStep[]
  views     PlanView[]
  shoppingList ShoppingListEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([difficulty])
  @@index([costTier])
  @@index([published])
  /// GIN is the right index for tsvector — it's what makes full-text search fast
  /// enough to run on every keystroke-ish request instead of scanning the table.
  @@index([searchVector], type: Gin)
}

/// Join table: which tools a plan needs, and whether each is truly required.
/// The `essential` flag is what makes "plans I can build with what I own"
/// answerable — an optional tool should not exclude a plan from your results.
model PlanTool {
  id     String @id @default(cuid())
  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id])

  essential Boolean @default(true)
  /// e.g. "A track saw works too" / "Only needed for the optional chamfer".
  note      String?

  @@unique([planId, toolId])
  @@index([toolId])
}

/// A material line item: lumber, hardware, glue, finish.
model Material {
  id     String @id @default(cuid())
  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  name     String
  /// "board feet", "linear feet", "each", "oz", "sheet"...
  unit     String
  quantity Float

  /// Wood species where relevant (Maple, Walnut, Pine). Null for hardware/finish.
  species  String?
  /// Estimated cost for THIS line, in integer cents. Null when it genuinely
  /// varies too much to estimate (e.g. "scrap you already have").
  costCents Int?
  note      String?

  sortOrder Int @default(0)

  steps StepMaterial[]

  @@index([planId])
}

/// A single part to cut, with finished dimensions. Stored in INCHES as floats —
/// unlike money, fractional inches are the natural unit and 0.75" is exact.
model CutListItem {
  id     String @id @default(cuid())
  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  part     String
  quantity Int

  thicknessIn Float
  widthIn     Float
  lengthIn    Float

  material String?
  note     String?

  sortOrder Int @default(0)

  @@index([planId])
}

/// One step of the build instructions. Markdown body.
model Step {
  id     String @id @default(cuid())
  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  stepNumber Int
  title      String
  body       String

  /// Sprint 21 — which of the PLAN'S tools and materials this step actually uses.
  tools     StepTool[]
  materials StepMaterial[]

  @@unique([planId, stepNumber])
  @@index([planId])
}

/// Join table: which tools a given STEP uses — Sprint 21. BUSINESS_PLAN.md §10.
///
/// A SUBSET of the plan's tools, never a superset. The plan's `PlanTool` list is still
/// the authoritative "what you need for the whole build"; this only says which of those
/// come out at which step, so a builder can gather what step 3 needs without reading
/// step 9. The subset rule is enforced at content-load time (src/content/load.ts), not
/// by the database — Postgres can't cheaply express "must also be one of this plan's
/// tools", and a foreign key to `Tool` alone would let a step reference a tool the plan
/// never declared. Getting that wrong would tell someone to fetch a lathe the plan
/// doesn't use.
///
/// NO `essential` flag here, on purpose: essentiality is a property of the tool for the
/// WHOLE plan (it already lives on PlanTool and drives the owned-tools filter).
/// Duplicating it per step invites the two copies to disagree.
model StepTool {
  id     String @id @default(cuid())
  stepId String
  step   Step   @relation(fields: [stepId], references: [id], onDelete: Cascade)
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id])

  @@unique([stepId, toolId])
  @@index([toolId])
}

/// Join table: which materials a given STEP uses — Sprint 21.
///
/// References a `Material` ROW, which is per-plan (materials have no global slug — they
/// are plan-local line items). The content file names them by their `name`, and the seed
/// resolves name → the plan's own material row; a name that isn't one of the plan's
/// materials fails to load, naming the file. Subset, same reasoning as StepTool.
model StepMaterial {
  id         String   @id @default(cuid())
  stepId     String
  step       Step     @relation(fields: [stepId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([stepId, materialId])
  @@index([materialId])
}

/// A photo or diagram. Sprint 1 stores URLs only — no upload pipeline yet.
model Image {
  id     String @id @default(cuid())
  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  url String
  /// Required, not optional: an accessible catalog is cheaper to build than to
  /// retrofit (Sprint 9 does an accessibility pass and will not have to fix this).
  alt String

  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  @@index([planId])
}
